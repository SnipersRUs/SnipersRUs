//@version=6
indicator("LHS Liquidity Hunter Signals", shorttitle="LHS LiqHunter", overlay=true)

// ── INPUTS
g1 = "Liquidity Detection"
useHTF = input.bool(true, "Use Higher Timeframe Analysis", group=g1, tooltip="Detect liquidity on higher timeframes for better accuracy")
htfTimeframe = input.timeframe("15", "Higher Timeframe", group=g1, tooltip="Timeframe to analyze liquidity (15m, 30m, 1H recommended)")
useAdaptiveThresholds = input.bool(true, "Auto-Adjust for Asset Type", group=g1, tooltip="Automatically adjust thresholds for BTC vs altcoins")
liqMinM = input.float(5.0, "Base Min Liquidation (M)", step=0.5, group=g1, tooltip="Base threshold - will auto-scale for BTC")
lookback = input.int(50, "Lookback (bars)", minval=20, group=g1)
zThresh = input.float(2.0, "Z-Score Threshold (Abnormal)", step=0.1, group=g1, tooltip="2.0+ = abnormal/major liquidations only. Lower = more signals but less selective")
adaptiveZ = input.bool(true, "Use Adaptive Z-Score", group=g1)
requireAbnormalOnly = input.bool(true, "Major Liquidations Only", group=g1, tooltip="Require both high liquidity AND abnormal z-score (2.0+)")

g2 = "Signal Settings"
showMajorSignals = input.bool(true, "Show Major Signals Only", group=g2, tooltip="Only show top-tier liquidation events")
showMinorSignals = input.bool(false, "Show Minor Signals", group=g2, tooltip="Show smaller liquidity sweeps (can be noisy)")
showStrongSignals = input.bool(true, "Show Strong Signals", group=g2)
signalSensitivity = input.float(0.5, "Signal Sensitivity", minval=0.3, maxval=1.0, step=0.1, group=g2, tooltip="Lower = fewer but higher quality signals")
minConfirmation = input.int(2, "Min Confirmation Factors", minval=1, maxval=4, group=g2, tooltip="Require at least this many factors (exhaustion, reversal, sweep) for signals")
signalCooldown = input.int(5, "Signal Cooldown (bars)", minval=2, maxval=20, group=g2, tooltip="Don't show another signal within this many bars")
requireVolumeConfirmation = input.bool(true, "Require Volume Confirmation", group=g2, tooltip="Only signal if volume is 2x+ average")
requirePriceRejection = input.bool(true, "Require Price Rejection", group=g2, tooltip="Only signal if price rejects cleanly after clearing")

g3 = "Advanced"
useExhaustion = input.bool(true, "Use Exhaustion Detection", group=g3)
useReversal = input.bool(true, "Use Reversal Patterns", group=g3)
useSweep = input.bool(true, "Use Stop Sweep Detection", group=g3)
exhaustionBars = input.int(3, "Exhaustion Lookback", minval=2, maxval=5, group=g3)

g4 = "Colors"
buySignalColor = input.color(#00FF88, "Buy Signal Color", group=g4)
sellSignalColor = input.color(#FF3366, "Sell Signal Color", group=g4)
strongBuyColor = input.color(#00FF00, "Strong Buy Signal", group=g4)
strongSellColor = input.color(#FF0000, "Strong Sell Signal", group=g4)

// ── TIMEFRAME DETECTION & ADAPTIVE MULTIPLIERS
currentTF = timeframe.in_seconds()
tfMinutes = currentTF / 60
isLTF = currentTF <= 300  // 5 minutes or less
isMTF = currentTF > 300 and currentTF <= 1800  // 5m to 30m
isHTF = currentTF > 1800  // Above 30m

// Timeframe-adaptive multiplier (LTF needs much higher thresholds)
float tfMultiplier = switch
    tfMinutes <= 1  => 5.0    // 1m: need 5x more liquidity
    tfMinutes <= 5  => 3.5    // 5m: 3.5x
    tfMinutes <= 15 => 2.5    // 15m: 2.5x
    tfMinutes <= 30 => 2.0    // 30m: 2x
    tfMinutes <= 60 => 1.5    // 1h: 1.5x
    => 1.0                    // 4h+: baseline

// ── CORE CALCULATIONS (Current Timeframe)
volumeM = volume / 1e6
rangePU = high - low
liqRawM = volumeM * rangePU
isBear = close < open
tickMove = math.abs(close - close[1])
tickVolume = tickMove > 0 ? volume / tickMove : volume
liqEnhancedM = (liqRawM * 0.7) + ((tickVolume / 1e6) * 0.3)
atr14 = ta.atr(14)

getVolatility() => atr14 / close
volatility = getVolatility()
adaptiveThreshold = adaptiveZ ? zThresh * (1 + volatility * 2) : zThresh

liqMean = ta.sma(liqEnhancedM, lookback)
liqStd = ta.stdev(liqEnhancedM, lookback)
z = liqStd > 0 ? (liqEnhancedM - liqMean) / liqStd : 0.0

// Volume confirmation (only show 2x+ average volume moves)
avgVolume = ta.sma(volume, 20)
volumeSpike = volume > avgVolume * 2.0

// ── ABNORMAL VOLUME DETECTION (Z-Score based)
volumeMean = ta.sma(volume, 50)
volumeStd = ta.stdev(volume, 50)
volumeZ = volumeStd > 0 ? (volume - volumeMean) / volumeStd : 0.0
abnormalVolume = volumeZ >= 2.0  // 2+ standard deviations = abnormal
veryAbnormalVolume = volumeZ >= 3.0  // 3+ = extremely abnormal

// ── ADAPTIVE THRESHOLD DETECTION (BTC vs Altcoins + Timeframe)
// Focus on MAJOR/ABNORMAL liquidations only - top percentile events
isHighLiquidityAsset = liqMean > 30.0  // Likely BTC or major pair
adaptiveLiqMinM = liqMinM

// Dynamic percentile-based threshold (top 5-10% of events)
dynamicMinLiq = ta.sma(liqEnhancedM, 200) * 2.5  // Must be 2.5x the 200-bar average

if useAdaptiveThresholds
    if isHighLiquidityAsset
        // For major pairs (BTC/ETH/SOL): on LTF, be less strict if abnormal volume
        // This allows signals on LTF when volume is truly abnormal
        baseThreshold = math.max(liqMinM, liqMean * 1.5)  // 1.5x mean = top tier
        // On LTF, reduce threshold by 30% if abnormal volume (allows more signals)
        ltfAdjustment = isLTF and abnormalVolume ? 0.7 : 1.0
        adaptiveLiqMinM := math.max(baseThreshold, dynamicMinLiq) * tfMultiplier * ltfAdjustment
    else
        // For alts: require top 10-15% of liquidity (major events only)
        baseThreshold = math.max(liqMinM, liqMean * 2.0)  // 2x mean = top tier
        adaptiveLiqMinM := math.max(baseThreshold, dynamicMinLiq * 0.8) * tfMultiplier
else
    // Even without adaptive, apply timeframe multiplier
    adaptiveLiqMinM := liqMinM * tfMultiplier

// ── HIGHER TIMEFRAME ANALYSIS
var float htfLiqEnhancedM = 0.0
var float htfZ = 0.0
var bool htfIsSignificant = false
var bool htfIsBear = false

if useHTF
    [htfVolume, htfHigh, htfLow, htfClose, htfOpen] = request.security(syminfo.tickerid, htfTimeframe, [volume, high, low, close, open], lookahead=barmerge.lookahead_off)
    htfVolumeM = htfVolume / 1e6
    htfRangePU = htfHigh - htfLow
    htfLiqRawM = htfVolumeM * htfRangePU
    htfIsBear := htfClose < htfOpen
    htfTickMove = math.abs(htfClose - htfClose[1])
    htfTickVolume = htfTickMove > 0 ? htfVolume / htfTickMove : htfVolume
    htfLiqEnhancedM := (htfLiqRawM * 0.7) + ((htfTickVolume / 1e6) * 0.3)

    htfLiqMean = ta.sma(htfLiqEnhancedM, lookback)
    htfLiqStd = ta.stdev(htfLiqEnhancedM, lookback)
    htfZ := htfLiqStd > 0 ? (htfLiqEnhancedM - htfLiqMean) / htfLiqStd : 0.0

    // Adaptive threshold for HTF - MAJOR liquidations only
    htfIsHighLiquidityAsset = htfLiqMean > 30.0
    htfDynamicMinLiq = ta.sma(htfLiqEnhancedM, 200) * 2.5
    htfAdaptiveLiqMinM = liqMinM
    if useAdaptiveThresholds
        if htfIsHighLiquidityAsset
            // For BTC on HTF: require top 5-10% (1.5x mean)
            baseThreshold = math.max(liqMinM, htfLiqMean * 1.5)
            htfAdaptiveLiqMinM := math.max(baseThreshold, htfDynamicMinLiq)
        else
            // For alts on HTF: require top 10-15% (2x mean)
            baseThreshold = math.max(liqMinM, htfLiqMean * 2.0)
            htfAdaptiveLiqMinM := math.max(baseThreshold, htfDynamicMinLiq * 0.8)

    htfHasEnoughData = bar_index >= lookback
    // Require BOTH high absolute liquidity AND abnormal z-score
    htfAbnormalZScore = htfHasEnoughData and htfZ >= zThresh  // Abnormal threshold
    htfMajorLiquidity = htfLiqEnhancedM >= htfAdaptiveLiqMinM
    htfTopPercentile = htfHasEnoughData and htfLiqEnhancedM >= htfLiqMean * 1.5  // Top tier
    // Volume confirmation for HTF
    htfAvgVolume = ta.sma(htfVolume, 20)
    htfVolumeSpike = htfVolume > htfAvgVolume * 2.0
    // HTF abnormal volume detection
    htfVolumeMean = ta.sma(htfVolume, 50)
    htfVolumeStd = ta.stdev(htfVolume, 50)
    htfVolumeZ = htfVolumeStd > 0 ? (htfVolume - htfVolumeMean) / htfVolumeStd : 0.0
    htfAbnormalVolume = htfVolumeZ >= 2.0
    htfVeryAbnormalVolume = htfVolumeZ >= 3.0
    // Only significant if it's both major liquidity AND abnormal (if required) AND volume spike
    // For major pairs: also allow if very abnormal volume
    if requireAbnormalOnly
        standardCheck = htfMajorLiquidity and htfAbnormalZScore and (not requireVolumeConfirmation or htfVolumeSpike)
        majorPairCheck = htfIsHighLiquidityAsset and htfVeryAbnormalVolume and htfLiqEnhancedM >= htfAdaptiveLiqMinM * 0.7 and htfZ >= zThresh * 0.8
        htfIsSignificant := standardCheck or majorPairCheck
    else
        standardCheck = htfMajorLiquidity and (htfAbnormalZScore or htfTopPercentile) and (not requireVolumeConfirmation or htfVolumeSpike)
        majorPairCheck = htfIsHighLiquidityAsset and htfVeryAbnormalVolume and htfLiqEnhancedM >= htfAdaptiveLiqMinM * 0.7
        htfIsSignificant := standardCheck or majorPairCheck

// ── MAJOR LIQUIDATION DETECTION (ABNORMAL EVENTS ONLY)
// Require BOTH high absolute liquidity AND abnormal z-score + volume confirmation
hasEnoughData = bar_index >= lookback
abnormalZScore = hasEnoughData and z >= zThresh  // Abnormal threshold
majorLiquidity = liqEnhancedM >= adaptiveLiqMinM
topPercentile = hasEnoughData and liqEnhancedM >= liqMean * 1.5  // Top tier liquidity

// For major pairs on LTF: allow signals with abnormal volume even if liquidity is slightly lower
bool currentIsSignificant = false
if requireAbnormalOnly
    // Standard: major liquidity AND abnormal z-score AND volume
    standardCheck = majorLiquidity and abnormalZScore and (not requireVolumeConfirmation or volumeSpike)
    // For major pairs on LTF: also allow if abnormal volume + decent liquidity
    majorPairLTFCheck = isHighLiquidityAsset and isLTF and abnormalVolume and veryAbnormalVolume and liqEnhancedM >= adaptiveLiqMinM * 0.7 and z >= zThresh * 0.8
    currentIsSignificant := standardCheck or majorPairLTFCheck
else
    standardCheck = majorLiquidity and (abnormalZScore or topPercentile) and (not requireVolumeConfirmation or volumeSpike)
    majorPairLTFCheck = isHighLiquidityAsset and isLTF and abnormalVolume and veryAbnormalVolume and liqEnhancedM >= adaptiveLiqMinM * 0.7
    currentIsSignificant := standardCheck or majorPairLTFCheck

// Combined significance: use HTF if enabled, otherwise use current TF
// Require BOTH high liquidity AND abnormal z-score for major liquidations
float effectiveLiq = 0.0
bool effectiveIsBear = false
isSignificant = false

if useHTF and htfIsSignificant
    // HTF already requires both major liquidity AND abnormal z-score
    isSignificant := true
    effectiveLiq := htfLiqEnhancedM
    effectiveIsBear := htfIsBear
else
    // Current TF: require both major liquidity AND abnormal z-score
    isSignificant := currentIsSignificant
    effectiveLiq := liqEnhancedM
    effectiveIsBear := isBear

// ── LIQUIDITY CLEARING DETECTION
// Track liquidity zones that get cleared
var float[] buyLiqLevels = array.new_float()
var float[] sellLiqLevels = array.new_float()
var int[] buyLiqBars = array.new_int()
var int[] sellLiqBars = array.new_int()

// Detect when significant liquidity appears (potential zone)
if isSignificant
    if effectiveIsBear
        // Sell liquidity zone
        liqLevel = (high + low) / 2
        array.push(sellLiqLevels, high)
        array.push(sellLiqBars, bar_index)
    else
        // Buy liquidity zone
        liqLevel = (high + low) / 2
        array.push(buyLiqLevels, low)
        array.push(buyLiqBars, bar_index)

// Clean old levels (keep last 10 - fewer zones = fewer signals)
if array.size(buyLiqLevels) > 10
    array.shift(buyLiqLevels)
    array.shift(buyLiqBars)
if array.size(sellLiqLevels) > 10
    array.shift(sellLiqLevels)
    array.shift(sellLiqBars)

// Check if liquidity zones were cleared
var float[] clearedBuyLevels = array.new_float()
var float[] clearedSellLevels = array.new_float()
var int[] clearedBuyBars = array.new_int()
var int[] clearedSellBars = array.new_int()

// Check buy liquidity clearing (price wicks below the zone)
if array.size(buyLiqLevels) > 0
    i = array.size(buyLiqLevels) - 1
    while i >= 0
        liqLevel = array.get(buyLiqLevels, i)
        liqBar = array.get(buyLiqBars, i)
        // Check if price cleared this level (low went below it)
        if low < liqLevel and (bar_index - liqBar) <= 50
            // Check if we haven't already recorded this clearance
            alreadyCleared = false
            if array.size(clearedBuyBars) > 0
                lastCleared = array.get(clearedBuyBars, array.size(clearedBuyBars) - 1)
                if lastCleared == liqBar
                    alreadyCleared := true
            if not alreadyCleared
                array.push(clearedBuyLevels, liqLevel)
                array.push(clearedBuyBars, bar_index)
            array.remove(buyLiqLevels, i)
            array.remove(buyLiqBars, i)
        i -= 1

// Check sell liquidity clearing (price wicks above the zone)
if array.size(sellLiqLevels) > 0
    i = array.size(sellLiqLevels) - 1
    while i >= 0
        liqLevel = array.get(sellLiqLevels, i)
        liqBar = array.get(sellLiqBars, i)
        // Check if price cleared this level (high went above it)
        if high > liqLevel and (bar_index - liqBar) <= 50
            // Check if we haven't already recorded this clearance
            alreadyCleared = false
            if array.size(clearedSellBars) > 0
                lastCleared = array.get(clearedSellBars, array.size(clearedSellBars) - 1)
                if lastCleared == liqBar
                    alreadyCleared := true
            if not alreadyCleared
                array.push(clearedSellLevels, liqLevel)
                array.push(clearedSellBars, bar_index)
            array.remove(sellLiqLevels, i)
            array.remove(sellLiqBars, i)
        i -= 1

// Clean old cleared levels
if array.size(clearedBuyLevels) > 10
    array.shift(clearedBuyLevels)
    array.shift(clearedBuyBars)
if array.size(clearedSellLevels) > 10
    array.shift(clearedSellLevels)
    array.shift(clearedSellBars)

// ── ENHANCED SIGNAL DETECTION
// Exhaustion detection
exhaustion_detected = false
if useExhaustion and effectiveLiq >= adaptiveLiqMinM
    vol_decay = true
    for i = 1 to exhaustionBars
        if i < bar_index and volume[i] >= volume[i - 1]
            vol_decay := false
    price_rejection = (effectiveIsBear and close > low + rangePU * 0.6) or (not effectiveIsBear and close < high - rangePU * 0.6)
    exhaustion_detected := vol_decay or price_rejection

// Reversal patterns
pin_bar = false
doji = false
reversal_candle = false
if useReversal
    pin_bar := rangePU > 0 and (((high - math.max(open, close)) / rangePU) > 0.6 or ((math.min(open, close) - low) / rangePU) > 0.6)
    doji := math.abs(close - open) < rangePU * 0.2
    reversal_candle := pin_bar or doji

// Stop sweep detection
sweep_detected = false
if useSweep
    [session_high, session_low, prev_high, prev_low] = request.security(syminfo.tickerid, "D", [high, low, high[1], low[1]], lookahead=barmerge.lookahead_off)
    sweep_detected := (high > prev_high and close < prev_high) or (low < prev_low and close > prev_low)

// ── LIQUIDITY CLUSTER DETECTION
// Market makers often stack liquidity at multiple levels - detect clusters
int nearbyBuyBoxes = 0
int nearbySellBoxes = 0
float priceRange = close * 0.02  // 2% range

if array.size(buyLiqLevels) > 0
    for i = 0 to array.size(buyLiqLevels) - 1
        liqLevel = array.get(buyLiqLevels, i)
        if math.abs(liqLevel - close) < priceRange
            nearbyBuyBoxes += 1

if array.size(sellLiqLevels) > 0
    for i = 0 to array.size(sellLiqLevels) - 1
        liqLevel = array.get(sellLiqLevels, i)
        if math.abs(liqLevel - close) < priceRange
            nearbySellBoxes += 1

bool isBuyCluster = nearbyBuyBoxes >= 3
bool isSellCluster = nearbySellBoxes >= 3

// ── PRICE REJECTION DETECTION
// Check if price immediately rejects after clearing liquidity
bool priceRejectionBuy = false
bool priceRejectionSell = false

if rangePU > 0
    // For buy bounce: did we reject hard off the cleared level?
    // Closed in top 30% of range AND bullish candle AND volume spike
    priceRejectionBuy := (close - low) / rangePU > 0.7 and (close > open) and volumeSpike

    // For sell bounce: did we reject hard off the cleared level?
    // Closed in bottom 30% of range AND bearish candle AND volume spike
    priceRejectionSell := (high - close) / rangePU > 0.7 and (close < open) and volumeSpike

// ── MAJOR VS MINOR EVENT CLASSIFICATION
// Determine if this is a major liquidation event or minor sweep
bool isMajorEvent = false
if isSignificant
    majorVolume = volume > avgVolume * 2.5  // 2.5x average volume
    majorZScore = z >= zThresh * 2.0  // 2x the threshold
    majorLiquidity = effectiveLiq >= adaptiveLiqMinM * 3.0  // 3x minimum
    // Include abnormal volume z-score in major event detection
    isMajorEvent := (majorVolume or veryAbnormalVolume) and majorZScore and majorLiquidity

// ── SIGNAL GENERATION WITH COOLDOWN
var int lastBuySignalBar = 0
var int lastSellSignalBar = 0

bool buySignal = false
bool sellSignal = false
bool strongBuySignal = false
bool strongSellSignal = false

// Buy signals (liquidity cleared from below, expect bounce up)
if array.size(clearedBuyBars) > 0
    lastClearedBar = array.get(clearedBuyBars, array.size(clearedBuyBars) - 1)
    lastClearedLevel = array.get(clearedBuyLevels, array.size(clearedBuyLevels) - 1)

    // Check cooldown
    inCooldown = bar_index - lastBuySignalBar < signalCooldown

    // Count confirmation factors (including abnormal volume)
    confirmationCount = 0
    if exhaustion_detected
        confirmationCount += 1
    if reversal_candle
        confirmationCount += 1
    if sweep_detected
        confirmationCount += 1
    if abnormalVolume
        confirmationCount += 1  // Abnormal volume adds confirmation
    if veryAbnormalVolume
        confirmationCount += 1  // Very abnormal volume adds extra confirmation

    // Require minimum confirmations AND price action confirmation
    priceActionConfirm = math.abs(low - lastClearedLevel) < atr14 * signalSensitivity
    hasEnoughConfirmations = confirmationCount >= minConfirmation

    // Signal on clearance - ONLY if we have enough confirmations and price action
    if bar_index == lastClearedBar and not inCooldown
        if hasEnoughConfirmations and priceActionConfirm
            // Require price rejection if enabled
            if not requirePriceRejection or priceRejectionBuy
                buySignal := true
                lastBuySignalBar := bar_index
                // Strong signal if: 3+ confirmations OR cluster hit OR major event
                if confirmationCount >= 3 or isBuyCluster or isMajorEvent
                    strongBuySignal := true

    // Bounce signal - stricter conditions, shorter window, require rejection
    if bar_index > lastClearedBar and bar_index <= lastClearedBar + 2 and not inCooldown
        distanceToLevel = math.abs(close - lastClearedLevel)
        bounceConfirm = close > lastClearedLevel and close[1] <= lastClearedLevel
        // Require bounce AND rejection AND at least 1 confirmation factor AND close distance
        if bounceConfirm and (not requirePriceRejection or priceRejectionBuy) and confirmationCount >= 1 and distanceToLevel < atr14 * signalSensitivity * 0.7
            buySignal := true
            lastBuySignalBar := bar_index
            if (confirmationCount >= 2 or isBuyCluster) and distanceToLevel < atr14 * 0.2
                strongBuySignal := true

// Sell signals (liquidity cleared from above, expect bounce down)
if array.size(clearedSellBars) > 0
    lastClearedBar = array.get(clearedSellBars, array.size(clearedSellBars) - 1)
    lastClearedLevel = array.get(clearedSellLevels, array.size(clearedSellLevels) - 1)

    // Check cooldown
    inCooldown = bar_index - lastSellSignalBar < signalCooldown

    // Count confirmation factors (including abnormal volume)
    confirmationCount = 0
    if exhaustion_detected
        confirmationCount += 1
    if reversal_candle
        confirmationCount += 1
    if sweep_detected
        confirmationCount += 1
    if abnormalVolume
        confirmationCount += 1  // Abnormal volume adds confirmation
    if veryAbnormalVolume
        confirmationCount += 1  // Very abnormal volume adds extra confirmation

    // Require minimum confirmations AND price action confirmation
    priceActionConfirm = math.abs(high - lastClearedLevel) < atr14 * signalSensitivity
    hasEnoughConfirmations = confirmationCount >= minConfirmation

    // Signal on clearance - ONLY if we have enough confirmations and price action
    if bar_index == lastClearedBar and not inCooldown
        if hasEnoughConfirmations and priceActionConfirm
            // Require price rejection if enabled
            if not requirePriceRejection or priceRejectionSell
                sellSignal := true
                lastSellSignalBar := bar_index
                // Strong signal if: 3+ confirmations OR cluster hit OR major event
                if confirmationCount >= 3 or isSellCluster or isMajorEvent
                    strongSellSignal := true

    // Bounce signal - stricter conditions, shorter window, require rejection
    if bar_index > lastClearedBar and bar_index <= lastClearedBar + 2 and not inCooldown
        distanceToLevel = math.abs(close - lastClearedLevel)
        bounceConfirm = close < lastClearedLevel and close[1] >= lastClearedLevel
        // Require bounce AND rejection AND at least 1 confirmation factor AND close distance
        if bounceConfirm and (not requirePriceRejection or priceRejectionSell) and confirmationCount >= 1 and distanceToLevel < atr14 * signalSensitivity * 0.7
            sellSignal := true
            lastSellSignalBar := bar_index
            if (confirmationCount >= 2 or isSellCluster) and distanceToLevel < atr14 * 0.2
                strongSellSignal := true

// ── PLOT SIGNALS (Two-Tier System: Major vs Minor)
// Major signals (always show if enabled)
plotshape(showMajorSignals and (strongBuySignal or (buySignal and isMajorEvent)), title="Major Buy Signal", style=shape.flag, location=location.belowbar, color=color.new(strongBuyColor, 0), size=size.normal)
plotshape(showMajorSignals and (strongSellSignal or (sellSignal and isMajorEvent)), title="Major Sell Signal", style=shape.flag, location=location.abovebar, color=color.new(strongSellColor, 0), size=size.normal)

// Minor signals (optional, only if enabled)
plotshape(showMinorSignals and buySignal and not isMajorEvent and not strongBuySignal, title="Minor Buy Signal", style=shape.flag, location=location.belowbar, color=color.new(buySignalColor, 0), size=size.tiny)
plotshape(showMinorSignals and sellSignal and not isMajorEvent and not strongSellSignal, title="Minor Sell Signal", style=shape.flag, location=location.abovebar, color=color.new(sellSignalColor, 0), size=size.tiny)

// ── INFO TABLE
if barstate.islast
    var table info = table.new(position.top_right, 2, 13, bgcolor=color.new(#1a1a1a, 85), border_width=1, border_color=color.new(#333333, 0))
    table.cell(info, 0, 0, "LHS Liquidity Hunter", bgcolor=color.new(#00FF88, 20), text_color=color.white, text_size=size.small, text_halign=text.align_center)
    table.merge_cells(info, 0, 0, 1, 0)

    tfLabel = useHTF ? htfTimeframe : timeframe.period
    table.cell(info, 0, 1, "Timeframe", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 1, tfLabel, text_color=color.white, text_size=size.tiny)

    assetType = useHTF ? (htfIsHighLiquidityAsset ? "BTC/Major" : "Alt") : (isHighLiquidityAsset ? "BTC/Major" : "Alt")
    table.cell(info, 0, 2, "Asset Type", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 2, assetType, text_color=color.yellow, text_size=size.tiny)

    table.cell(info, 0, 3, "Liquidity", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 3, str.tostring(effectiveLiq, "#.#") + "M", text_color=color.white, text_size=size.tiny)

    adaptiveThreshold = useHTF ? (useAdaptiveThresholds ? htfAdaptiveLiqMinM : liqMinM) : (useAdaptiveThresholds ? adaptiveLiqMinM : liqMinM)
    table.cell(info, 0, 4, "Threshold", text_color=color.gray, text_size=size.tiny)
    table.cell(info, 1, 4, str.tostring(adaptiveThreshold, "#.#") + "M", text_color=color.cyan, text_size=size.tiny)

    table.cell(info, 0, 5, "Z-Score", text_color=color.gray, text_size=size.tiny)
    zColor = (useHTF ? htfZ : z) >= zThresh ? color.yellow : color.white
    table.cell(info, 1, 5, str.tostring(useHTF ? htfZ : z, "#.##"), text_color=zColor, text_size=size.tiny)

    table.cell(info, 0, 6, "Significant", text_color=color.gray, text_size=size.tiny)
    sigColor = isSignificant ? color.lime : color.red
    table.cell(info, 1, 6, isSignificant ? "✓" : "✗", text_color=sigColor, text_size=size.tiny)

    table.cell(info, 0, 7, "Exhaustion", text_color=color.gray, text_size=size.tiny)
    exhColor = exhaustion_detected ? color.lime : color.red
    table.cell(info, 1, 7, exhaustion_detected ? "✓" : "✗", text_color=exhColor, text_size=size.tiny)

    table.cell(info, 0, 8, "Reversal", text_color=color.gray, text_size=size.tiny)
    revColor = reversal_candle ? color.lime : color.red
    table.cell(info, 1, 8, reversal_candle ? "✓" : "✗", text_color=revColor, text_size=size.tiny)

    table.cell(info, 0, 9, "Volume Spike", text_color=color.gray, text_size=size.tiny)
    volColor = volumeSpike ? color.lime : color.red
    table.cell(info, 1, 9, volumeSpike ? "✓" : "✗", text_color=volColor, text_size=size.tiny)

    table.cell(info, 0, 10, "Abnormal Vol", text_color=color.gray, text_size=size.tiny)
    abnVolText = veryAbnormalVolume ? "🔥" : (abnormalVolume ? "✓" : "✗")
    abnVolColor = veryAbnormalVolume ? color.orange : (abnormalVolume ? color.lime : color.red)
    table.cell(info, 1, 10, abnVolText, text_color=abnVolColor, text_size=size.tiny)

    clusterStatus = isBuyCluster ? "Buy(" + str.tostring(nearbyBuyBoxes) + ")" : isSellCluster ? "Sell(" + str.tostring(nearbySellBoxes) + ")" : "None"
    table.cell(info, 0, 11, "Cluster", text_color=color.gray, text_size=size.tiny)
    clusterColor = (isBuyCluster or isSellCluster) ? color.yellow : color.gray
    table.cell(info, 1, 11, clusterStatus, text_color=clusterColor, text_size=size.tiny)

    table.cell(info, 0, 12, "Major Event", text_color=color.gray, text_size=size.tiny)
    majorColor = isMajorEvent ? color.orange : color.gray
    table.cell(info, 1, 12, isMajorEvent ? "🔥" : "✗", text_color=majorColor, text_size=size.tiny)

// ── ALERTS
alertcondition(strongBuySignal, "Strong Buy Signal", "LHS: Strong Buy Liquidity Signal")
alertcondition(strongSellSignal, "Strong Sell Signal", "LHS: Strong Sell Liquidity Signal")
alertcondition(buySignal, "Buy Signal", "LHS: Buy Liquidity Signal")
alertcondition(sellSignal, "Sell Signal", "LHS: Sell Liquidity Signal")
