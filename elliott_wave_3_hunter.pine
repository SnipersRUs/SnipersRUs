//@version=6
indicator("Complete Elliott Wave 5-Wave System", shorttitle="EW5 System", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ────────────────────────────────────────────────────────────────────────
//  INPUTS
// ────────────────────────────────────────────────────────────────────────
// Timeframe Settings
use_auto_params = input.bool(true, "Auto-Adjust for Timeframe", tooltip="Automatically adjust parameters based on chart timeframe")
manual_swing_len = input.int(10, "Manual Swing Length", minval=3, tooltip="Number of bars for swing detection")

// Wave Detection Parameters
w1_min_pct = input.float(0.5, "Wave 1 Min Move %", minval=0.3, step=0.1, tooltip="Minimum % move for Wave 1")
w2_retrace_min = input.float(0.382, "Wave 2 Min Retrace", minval=0.236, step=0.01)
w2_retrace_max = input.float(0.786, "Wave 2 Max Retrace", minval=0.5, step=0.01)
w4_retrace_min = input.float(0.236, "Wave 4 Min Retrace", minval=0.15, step=0.01)
w4_retrace_max = input.float(0.382, "Wave 4 Max Retrace", minval=0.236, step=0.01)

// Wave Validation Rules
w3_min_extension = input.float(1.618, "Wave 3 Min Extension", minval=1.0, step=0.1, tooltip="Wave 3 must be at least this % of Wave 1")
w5_min_extension = input.float(0.618, "Wave 5 Min Extension", minval=0.382, step=0.1, tooltip="Wave 5 minimum extension of Wave 1")

// Entry Confirmation
rsi_period = input.int(14, "RSI Period")
rsi_oversold = input.int(35, "RSI Oversold", minval=20, maxval=50)
rsi_overbought = input.int(65, "RSI Overbought", minval=50, maxval=80)
use_volume = input.bool(true, "Use Volume Confirmation", tooltip="Require volume confirmation for Wave 3")
require_engulfing = input.bool(true, "Require Engulfing Candle", tooltip="Require engulfing candle for entry signals")

// Auto-Invalidation
max_wave_bars = input.int(50, "Max Bars Per Wave", minval=20, maxval=200, tooltip="Invalidate if wave takes too long")

// Get adaptive max bars based on timeframe
get_max_wave_bars() =>
    if timeframe.isintraday
        if timeframe.multiplier <= 5
            30
        else if timeframe.multiplier <= 15
            40
        else if timeframe.multiplier <= 30
            60
        else if timeframe.multiplier <= 60
            80
        else
            100
    else if timeframe.isdaily
        50
    else if timeframe.isweekly
        20
    else
        max_wave_bars

adaptive_max_bars = get_max_wave_bars()

// Visuals
show_waves = input.bool(true, "Show Wave Labels")
show_projections = input.bool(true, "Show Wave Projections")
show_entry_zones = input.bool(true, "Show Entry Zones")
show_stops = input.bool(true, "Show Stop Loss Levels")
show_htf = input.bool(true, "Show Higher Timeframe Context")

// ────────────────────────────────────────────────────────────────────────
//  WAVE STRUCTURE VARIABLES
// ────────────────────────────────────────────────────────────────────────
// Wave State: 0 = No wave, 1-5 = Impulse waves, 6-8 = ABC correction (A=6, B=7, C=8)
var int current_wave = 0
var bool is_bullish_impulse = true

// Wave 1
var float w1_start = na
var float w1_end = na
var int w1_start_bar = na
var int w1_end_bar = na

// Wave 2
var float w2_start = na
var float w2_end = na
var int w2_start_bar = na
var int w2_end_bar = na

// Wave 3
var float w3_start = na
var float w3_end = na
var int w3_start_bar = na
var int w3_end_bar = na

// Wave 4
var float w4_start = na
var float w4_end = na
var int w4_start_bar = na
var int w4_end_bar = na

// Wave 5
var float w5_start = na
var float w5_end = na
var int w5_start_bar = na
var int w5_end_bar = na

// ABC Correction
var float wave_a_start = na
var float wave_a_end = na
var float wave_b_start = na
var float wave_b_end = na
var float wave_c_start = na
var float wave_c_end = na
var int wave_a_start_bar = na
var int wave_a_bar = na
var int wave_b_start_bar = na
var int wave_b_bar = na
var int wave_c_start_bar = na
var int wave_c_bar = na

// Drawing objects
var array<line> wave_lines = array.new<line>()
var array<label> wave_labels = array.new<label>()
var array<line> projection_lines = array.new<line>()

// ────────────────────────────────────────────────────────────────────────
//  HELPER FUNCTIONS
// ────────────────────────────────────────────────────────────────────────
get_swing_length() =>
    if not use_auto_params
        manual_swing_len
    else
        // More adaptive swing length for different timeframes
        if timeframe.isintraday
            if timeframe.multiplier <= 5
                5
            else if timeframe.multiplier <= 15
                7
            else if timeframe.multiplier <= 30
                10
            else if timeframe.multiplier <= 60
                15
            else
                20
        else if timeframe.isdaily
            10
        else if timeframe.isweekly
            5
        else
            10

swing_len = get_swing_length()

// Calculate wave length in price
wave_length(start_price, end_price) => math.abs(end_price - start_price)

// Calculate wave length in bars
wave_bars(start_bar, end_bar) => end_bar - start_bar

// Check if Wave 4 overlaps Wave 1 (invalidates structure)
wave4_overlaps_wave1() =>
    if na(w4_end) or na(w1_end) or na(w1_start)
        false
    else
        is_bullish_impulse ? (w4_end < w1_end) : (w4_end > w1_end)

// Check if Wave 3 is shortest (invalidates - Wave 3 cannot be shortest)
wave3_is_shortest() =>
    if na(w3_end) or na(w3_start) or na(w1_end) or na(w1_start)
        false
    else
        w3_length = wave_length(w3_start, w3_end)
        w1_length = wave_length(w1_start, w1_end)
        w5_length = na(w5_end) or na(w5_start) ? 999999999 : wave_length(w5_start, w5_end)
        w3_length < w1_length and w3_length < w5_length

// ────────────────────────────────────────────────────────────────────────
//  WAVE DETECTION LOGIC
// ────────────────────────────────────────────────────────────────────────
// Calculate indicators
current_rsi = ta.rsi(close, rsi_period)
ema_fast = ta.ema(close, 9)
avg_volume = ta.sma(volume, 20)
volume_spike = volume > avg_volume * 1.5

// Swing detection
swing_high = ta.highest(high, swing_len)
swing_low = ta.lowest(low, swing_len)

// Price action confirmation
bullish_engulfing = close > open and close[1] < open[1] and close > open[1] and open < close[1]
bearish_engulfing = close < open and close[1] > open[1] and close < open[1] and open > close[1]
momentum_candle = math.abs(close - open) > math.abs(high - low) * 0.6

// ────────────────────────────────────────────────────────────────────────
//  WAVE 1 DETECTION
// ────────────────────────────────────────────────────────────────────────
if current_wave == 0
    // Detect initial impulse move
    move_pct = swing_low > 0 ? ((swing_high - swing_low) / swing_low * 100) : 0
    is_strong_move = move_pct > w1_min_pct

    // Bullish Wave 1
    if is_strong_move and high >= swing_high * 0.998 and close < high[1] and na(w1_end)
        w1_start := swing_low
        w1_end := swing_high
        w1_end_bar := bar_index
        w1_start_bar := bar_index - swing_len
        current_wave := 1
        is_bullish_impulse := true

    // Bearish Wave 1
    if is_strong_move and low <= swing_low * 1.002 and close > low[1] and na(w1_end)
        w1_start := swing_high
        w1_end := swing_low
        w1_end_bar := bar_index
        w1_start_bar := bar_index - swing_len
        current_wave := 1
        is_bullish_impulse := false

// ────────────────────────────────────────────────────────────────────────
//  WAVE 2 DETECTION
// ────────────────────────────────────────────────────────────────────────
if current_wave == 1 and not na(w1_end) and not na(w1_start)
    w1_range = wave_length(w1_start, w1_end)
    w2_retrace_38 = is_bullish_impulse ? (w1_end - w1_range * 0.382) : (w1_end + w1_range * 0.382)
    w2_retrace_61 = is_bullish_impulse ? (w1_end - w1_range * 0.618) : (w1_end + w1_range * 0.618)
    w2_retrace_78 = is_bullish_impulse ? (w1_end - w1_range * 0.786) : (w1_end + w1_range * 0.786)

    // Check if price retraced into Wave 2 zone
    in_w2_zone = is_bullish_impulse ? (close <= w2_retrace_38 and close >= w2_retrace_78) : (close >= w2_retrace_38 and close <= w2_retrace_78)

    // Wave 2 should not exceed Wave 1 start
    w2_valid = is_bullish_impulse ? (close >= w1_start) : (close <= w1_start)

    // Detect Wave 2 end (price starts moving back in impulse direction)
    if in_w2_zone and w2_valid
        w2_start := w1_end
        w2_start_bar := w1_end_bar

        // Wave 2 ends when price reverses
        if is_bullish_impulse and close > close[1] and close > ema_fast and current_rsi > rsi_oversold
            w2_end := low
            w2_end_bar := bar_index
            current_wave := 2
        else if not is_bullish_impulse and close < close[1] and close < ema_fast and current_rsi < rsi_overbought
            w2_end := high
            w2_end_bar := bar_index
            current_wave := 2

    // Invalidate if Wave 2 exceeds Wave 1 start
    if not w2_valid
        // Reset to Wave 1
        current_wave := 1
        w2_start := na
        w2_end := na
        w2_start_bar := na
        w2_end_bar := na

    // Time-based invalidation
    if not na(w1_end_bar) and bar_index - w1_end_bar > adaptive_max_bars
        current_wave := 0
        w1_start := na
        w1_end := na
        w1_start_bar := na
        w1_end_bar := na

// ────────────────────────────────────────────────────────────────────────
//  WAVE 3 DETECTION
// ────────────────────────────────────────────────────────────────────────
if current_wave == 2 and not na(w2_end) and not na(w1_start) and not na(w1_end)
    w1_length = wave_length(w1_start, w1_end)
    w3_start := w2_end
    w3_start_bar := w2_end_bar

    // Wave 3 projection targets
    w3_target_161 = is_bullish_impulse ? (w2_end + w1_length * 1.618) : (w2_end - w1_length * 1.618)
    w3_target_200 = is_bullish_impulse ? (w2_end + w1_length * 2.0) : (w2_end - w1_length * 2.0)
    w3_target_261 = is_bullish_impulse ? (w2_end + w1_length * 2.618) : (w2_end - w1_length * 2.618)

    // Wave 3 must extend beyond Wave 1 end
    w3_extending = is_bullish_impulse ? (close > w1_end) : (close < w1_end)

    // Detect Wave 3 end (momentum slows, starts retracing)
    if w3_extending
        // Wave 3 typically has highest volume
        volume_confirmed = not use_volume or volume_spike

        // Check for Wave 3 completion (price starts pulling back)
        w3_pullback = is_bullish_impulse ? (close < high[1] and close < close[2]) : (close > low[1] and close > close[2])

        if w3_pullback and volume_confirmed
            w3_end := is_bullish_impulse ? high : low
            w3_end_bar := bar_index
            w3_length = wave_length(w3_start, w3_end)

            // Validate Wave 3 is not shortest
            if w3_length >= w1_length * w3_min_extension and not wave3_is_shortest()
                current_wave := 3
            else
                // Invalid Wave 3, reset
                current_wave := 0
                w1_start := na
                w1_end := na
                w2_start := na
                w2_end := na
                w3_start := na
                w3_end := na

    // Time-based invalidation
    if not na(w2_end_bar) and bar_index - w2_end_bar > adaptive_max_bars
        current_wave := 0
        w1_start := na
        w1_end := na
        w2_start := na
        w2_end := na
        w3_start := na
        w3_end := na

// ────────────────────────────────────────────────────────────────────────
//  WAVE 4 DETECTION
// ────────────────────────────────────────────────────────────────────────
if current_wave == 3 and not na(w3_end) and not na(w3_start)
    w3_range = wave_length(w3_start, w3_end)
    w4_retrace_23 = is_bullish_impulse ? (w3_end - w3_range * 0.236) : (w3_end + w3_range * 0.236)
    w4_retrace_38 = is_bullish_impulse ? (w3_end - w3_range * 0.382) : (w3_end + w3_range * 0.382)

    w4_start := w3_end
    w4_start_bar := w3_end_bar

    // Wave 4 should retrace 23.6% to 38.2% of Wave 3
    in_w4_zone = is_bullish_impulse ? (close <= w4_retrace_23 and close >= w4_retrace_38) : (close >= w4_retrace_23 and close <= w4_retrace_38)

    // Critical: Wave 4 cannot overlap Wave 1
    no_overlap = is_bullish_impulse ? (close > w1_end) : (close < w1_end)

    if in_w4_zone and no_overlap
        // Wave 4 ends when price reverses
        if is_bullish_impulse and close > close[1] and current_rsi > rsi_oversold
            w4_end := low
            w4_end_bar := bar_index

            // Validate no overlap
            if not wave4_overlaps_wave1()
                current_wave := 4
            else
                // Invalid - Wave 4 overlapped Wave 1
                current_wave := 0
                w1_start := na
                w1_end := na
                w2_start := na
                w2_end := na
                w3_start := na
                w3_end := na
                w4_start := na
                w4_end := na

    // Invalidate if overlap occurs
    if not no_overlap
        current_wave := 0
        w1_start := na
        w1_end := na
        w2_start := na
        w2_end := na
        w3_start := na
        w3_end := na
        w4_start := na
        w4_end := na

    // Time-based invalidation
    if not na(w3_end_bar) and bar_index - w3_end_bar > adaptive_max_bars
        current_wave := 0
        w1_start := na
        w1_end := na
        w2_start := na
        w2_end := na
        w3_start := na
        w3_end := na
        w4_start := na
        w4_end := na

// ────────────────────────────────────────────────────────────────────────
//  WAVE 5 DETECTION
// ────────────────────────────────────────────────────────────────────────
if current_wave == 4 and not na(w4_end) and not na(w1_start) and not na(w1_end) and not na(w3_end) and not na(w3_start)
    w1_length = wave_length(w1_start, w1_end)
    w5_start := w4_end
    w5_start_bar := w4_end_bar

    // Wave 5 projections (often equals Wave 1 or 61.8% of Wave 1-3)
    w1_to_w3 = wave_length(w1_start, w3_end)
    w5_target_618 = is_bullish_impulse ? (w4_end + w1_to_w3 * 0.618) : (w4_end - w1_to_w3 * 0.618)
    w5_target_100 = is_bullish_impulse ? (w4_end + w1_length) : (w4_end - w1_length)

    // Wave 5 must extend beyond Wave 3 end (in most cases)
    w5_extending = is_bullish_impulse ? (close > w3_end) : (close < w3_end)

    if w5_extending
        // Wave 5 often shows divergence (price up, momentum down)
        rsi_5_bars_ago = ta.rsi(close, rsi_period)[5]
        rsi_divergence = is_bullish_impulse ? (close > close[5] and current_rsi < rsi_5_bars_ago) : (close < close[5] and current_rsi > rsi_5_bars_ago)

        // Detect Wave 5 completion
        w5_pullback = is_bullish_impulse ? (close < high[1] and close < high[2]) : (close > low[1] and close > low[2])

        if w5_pullback or rsi_divergence
            w5_end := is_bullish_impulse ? high : low
            w5_end_bar := bar_index
            w5_length = wave_length(w5_start, w5_end)

            if w5_length >= w1_length * w5_min_extension
                current_wave := 5
            else
                current_wave := 0
                w1_start := na
                w1_end := na
                w2_start := na
                w2_end := na
                w3_start := na
                w3_end := na
                w4_start := na
                w4_end := na
                w5_start := na
                w5_end := na

    // Time-based invalidation
    if not na(w4_end_bar) and bar_index - w4_end_bar > adaptive_max_bars
        current_wave := 0
        w1_start := na
        w1_end := na
        w2_start := na
        w2_end := na
        w3_start := na
        w3_end := na
        w4_start := na
        w4_end := na
        w5_start := na
        w5_end := na

// ────────────────────────────────────────────────────────────────────────
//  ABC CORRECTION DETECTION (After Wave 5)
// ────────────────────────────────────────────────────────────────────────
if current_wave == 5 and not na(w5_end)
    // After Wave 5 completes, expect ABC correction
    wave_a_start := w5_end
    wave_a_start_bar := w5_end_bar

    // Wave A: First leg of correction (impulsive)
    if na(wave_a_end)
        // Wave A typically retraces 38.2% to 61.8% of Wave 5
        w5_range = wave_length(w5_start, w5_end)
        wave_a_target_38 = is_bullish_impulse ? (w5_end - w5_range * 0.382) : (w5_end + w5_range * 0.382)
        wave_a_target_61 = is_bullish_impulse ? (w5_end - w5_range * 0.618) : (w5_end + w5_range * 0.618)

        in_wave_a_zone = is_bullish_impulse ? (close <= wave_a_target_38 and close >= wave_a_target_61) : (close >= wave_a_target_38 and close <= wave_a_target_61)

        if in_wave_a_zone
            // Wave A ends when price reverses
            if is_bullish_impulse and close > close[1] and current_rsi > rsi_oversold
                wave_a_end := low
                wave_a_bar := bar_index
                current_wave := 6  // Wave A complete
            else if not is_bullish_impulse and close < close[1] and current_rsi < rsi_overbought
                wave_a_end := high
                wave_a_bar := bar_index
                current_wave := 6  // Wave A complete

    // Wave B: Counter-trend bounce (corrective)
    if current_wave == 6 and not na(wave_a_end)
        wave_b_start := wave_a_end
        wave_b_start_bar := wave_a_bar

        // Wave B typically retraces 38.2% to 78.6% of Wave A
        wave_a_range = wave_length(wave_a_start, wave_a_end)
        wave_b_target_38 = is_bullish_impulse ? (wave_a_end + wave_a_range * 0.382) : (wave_a_end - wave_a_range * 0.382)
        wave_b_target_78 = is_bullish_impulse ? (wave_a_end + wave_a_range * 0.786) : (wave_a_end - wave_a_range * 0.786)

        in_wave_b_zone = is_bullish_impulse ? (close >= wave_b_target_38 and close <= wave_b_target_78) : (close <= wave_b_target_38 and close >= wave_b_target_78)

        if in_wave_b_zone
            // Wave B ends when price reverses
            if is_bullish_impulse and close < close[1] and current_rsi < rsi_overbought
                wave_b_end := high
                wave_b_bar := bar_index
                current_wave := 7  // Wave B complete
            else if not is_bullish_impulse and close > close[1] and current_rsi > rsi_oversold
                wave_b_end := low
                wave_b_bar := bar_index
                current_wave := 7  // Wave B complete

    // Wave C: Final leg of correction (impulsive, often equals Wave A)
    if current_wave == 7 and not na(wave_b_end)
        wave_c_start := wave_b_end
        wave_c_start_bar := wave_b_bar

        // Wave C often equals Wave A or extends to 100% or 161.8%
        wave_a_range = wave_length(wave_a_start, wave_a_end)
        wave_c_target_100 = is_bullish_impulse ? (wave_b_end - wave_a_range) : (wave_b_end + wave_a_range)
        wave_c_target_161 = is_bullish_impulse ? (wave_b_end - wave_a_range * 1.618) : (wave_b_end + wave_a_range * 1.618)

        // Wave C should complete the correction
        if is_bullish_impulse and close <= wave_c_target_100
            wave_c_end := low
            wave_c_bar := bar_index
            current_wave := 8  // ABC complete, ready for new impulse
        else if not is_bullish_impulse and close >= wave_c_target_100
            wave_c_end := high
            wave_c_bar := bar_index
            current_wave := 8  // ABC complete

// ────────────────────────────────────────────────────────────────────────
//  ENTRY SIGNALS
// ────────────────────────────────────────────────────────────────────────
// Wave 3 Entry (after Wave 2 completes)
w3_entry_signal = current_wave == 2 and not na(w2_end) and ((is_bullish_impulse and close > close[1] and (not require_engulfing or bullish_engulfing)) or (not is_bullish_impulse and close < close[1] and (not require_engulfing or bearish_engulfing)))

// Wave 5 Entry (after Wave 4 completes)
w5_entry_signal = current_wave == 4 and not na(w4_end) and ((is_bullish_impulse and close > close[1] and (not require_engulfing or bullish_engulfing)) or (not is_bullish_impulse and close < close[1] and (not require_engulfing or bearish_engulfing)))

// Wave C Entry (counter-trend after Wave 5)
wave_c_entry_signal = current_wave == 7 and not na(wave_b_end) and ((is_bullish_impulse and close < close[1] and (not require_engulfing or bearish_engulfing)) or (not is_bullish_impulse and close > close[1] and (not require_engulfing or bullish_engulfing)))

// ────────────────────────────────────────────────────────────────────────
//  STOP LOSS LEVELS
// ────────────────────────────────────────────────────────────────────────
w3_stop = current_wave >= 2 and not na(w2_end) ? (is_bullish_impulse ? w2_end * 0.995 : w2_end * 1.005) : na
w5_stop = current_wave >= 4 and not na(w4_end) ? (is_bullish_impulse ? w4_end * 0.995 : w4_end * 1.005) : na
wave_c_stop = current_wave == 7 and not na(wave_b_end) ? (is_bullish_impulse ? wave_b_end * 1.005 : wave_b_end * 0.995) : na

// Flag for plotting when 5 waves are complete (used in visuals below)
five_waves_complete_now = current_wave == 5 and not na(w5_end)

// ────────────────────────────────────────────────────────────────────────
//  PLOTTING
// ────────────────────────────────────────────────────────────────────────
// Draw Wave Lines and Labels
if show_waves
    // Wave 1
    if not na(w1_end) and not na(w1_start_bar) and not na(w1_end_bar)
        line.new(w1_start_bar, w1_start, w1_end_bar, w1_end, color=color.new(color.blue, 0), width=2)
        label.new(w1_end_bar, w1_end, "1", style=label.style_label_down, color=color.blue, textcolor=color.white, size=size.normal)

    // Wave 2
    if not na(w2_end) and not na(w2_start_bar) and not na(w2_end_bar)
        line.new(w2_start_bar, w2_start, w2_end_bar, w2_end, color=color.new(color.red, 0), width=2, style=line.style_dashed)
        label.new(w2_end_bar, w2_end, "2", style=label.style_label_up, color=color.red, textcolor=color.white, size=size.normal)

    // Wave 3 - with direction indicator
    if not na(w3_end) and not na(w3_start_bar) and not na(w3_end_bar)
        w3_color = is_bullish_impulse ? color.new(color.green, 0) : color.new(color.red, 0)
        w3_text = is_bullish_impulse ? "3↑" : "3↓"
        line.new(w3_start_bar, w3_start, w3_end_bar, w3_end, color=w3_color, width=3)
        label.new(w3_end_bar, w3_end, w3_text, style=label.style_label_down, color=w3_color, textcolor=color.white, size=size.large)

    // Wave 4
    if not na(w4_end) and not na(w4_start_bar) and not na(w4_end_bar)
        line.new(w4_start_bar, w4_start, w4_end_bar, w4_end, color=color.new(color.orange, 0), width=2, style=line.style_dashed)
        label.new(w4_end_bar, w4_end, "4", style=label.style_label_up, color=color.orange, textcolor=color.white, size=size.normal)

    // Wave 5 - with completion indicator
    if not na(w5_end) and not na(w5_start_bar) and not na(w5_end_bar)
        line.new(w5_start_bar, w5_start, w5_end_bar, w5_end, color=color.new(color.purple, 0), width=2)
        w5_label_text = "5✓"  // Checkmark indicates 5 waves complete
        label.new(w5_end_bar, w5_end, w5_label_text, style=label.style_label_down, color=color.new(color.purple, 0), textcolor=color.white, size=size.large)

        // Add "REVERSAL" label when 5 waves complete
        if five_waves_complete_now
            reversal_text = "REVERSAL\n" + (is_bullish_impulse ? "↓ BEARISH" : "↑ BULLISH")
            label.new(w5_end_bar, w5_end, reversal_text, style=label.style_label_center, color=color.new(color.red, 0), textcolor=color.white, size=size.large)

    // ABC Correction
    if not na(wave_a_end) and not na(wave_a_bar)
        label.new(wave_a_bar, wave_a_end, "A", style=label.style_label_up, color=color.yellow, textcolor=color.black, size=size.small)
    if not na(wave_b_end) and not na(wave_b_bar)
        label.new(wave_b_bar, wave_b_end, "B", style=label.style_label_down, color=color.yellow, textcolor=color.black, size=size.small)
    if not na(wave_c_end) and not na(wave_c_bar)
        label.new(wave_c_bar, wave_c_end, "C", style=label.style_label_up, color=color.yellow, textcolor=color.black, size=size.small)

// Wave Projections
if show_projections and current_wave == 2 and not na(w2_end)
    w1_length = wave_length(w1_start, w1_end)
    w3_target_161 = is_bullish_impulse ? (w2_end + w1_length * 1.618) : (w2_end - w1_length * 1.618)
    line.new(bar_index, w2_end, bar_index + 20, w3_target_161, color=color.new(color.green, 70), width=1, style=line.style_dashed, extend=extend.right)

if show_projections and current_wave == 4 and not na(w4_end)
    w1_length = wave_length(w1_start, w1_end)
    w5_target_100 = is_bullish_impulse ? (w4_end + w1_length) : (w4_end - w1_length)
    line.new(bar_index, w4_end, bar_index + 20, w5_target_100, color=color.new(color.purple, 70), width=1, style=line.style_dashed, extend=extend.right)

// Entry Signals
plotshape(show_entry_zones and w3_entry_signal, style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.normal, text="W3")
plotshape(show_entry_zones and w5_entry_signal, style=shape.triangleup, location=location.belowbar, color=color.new(color.purple, 0), size=size.normal, text="W5")
plotshape(show_entry_zones and wave_c_entry_signal, style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow, 0), size=size.normal, text="C")

// Stop Loss Levels
plot(show_stops and not na(w3_stop) ? w3_stop : na, "W3 Stop", color=color.new(color.red, 50), linewidth=1, style=plot.style_line)
plot(show_stops and not na(w5_stop) ? w5_stop : na, "W5 Stop", color=color.new(color.red, 50), linewidth=1, style=plot.style_line)
plot(show_stops and not na(wave_c_stop) ? wave_c_stop : na, "Wave C Stop", color=color.new(color.red, 50), linewidth=1, style=plot.style_line)

// ────────────────────────────────────────────────────────────────────────
//  5-WAVE COMPLETION DETECTION
// ────────────────────────────────────────────────────────────────────────
// Track when 5 waves complete for reversal alert
var bool w5_completed_alerted = false
five_waves_complete = current_wave == 5 and not na(w5_end) and not w5_completed_alerted
if five_waves_complete
    w5_completed_alerted := true

// Reset alert flag when new wave structure starts
if current_wave == 0
    w5_completed_alerted := false

// ────────────────────────────────────────────────────────────────────────
//  ALERTS
// ────────────────────────────────────────────────────────────────────────
// Wave 3 Entry Alerts (separate for bullish/bearish)
alertcondition(w3_entry_signal and is_bullish_impulse, "Wave 3 Entry - BULLISH", "Wave 3 BULLISH entry signal on {{ticker}}")
alertcondition(w3_entry_signal and not is_bullish_impulse, "Wave 3 Entry - BEARISH", "Wave 3 BEARISH entry signal on {{ticker}}")
alertcondition(w5_entry_signal, "Wave 5 Entry", "Wave 5 entry signal on {{ticker}}")
alertcondition(wave_c_entry_signal, "Wave C Entry", "Wave C correction entry signal on {{ticker}}")
// 5-Wave Completion Alerts (separate for bullish/bearish)
alertcondition(five_waves_complete and is_bullish_impulse, "5 Waves Complete - BULLISH REVERSAL", "5-Wave BULLISH impulse completed on {{ticker}} - REVERSAL ALERT! Expect bearish correction")
alertcondition(five_waves_complete and not is_bullish_impulse, "5 Waves Complete - BEARISH REVERSAL", "5-Wave BEARISH impulse completed on {{ticker}} - REVERSAL ALERT! Expect bullish correction")
alertcondition(current_wave == 8, "ABC Complete", "ABC correction completed on {{ticker}} - Ready for new impulse")
