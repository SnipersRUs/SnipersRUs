//@version=6
indicator("Bounty Seeker", overlay=true, max_lines_count=500, max_labels_count=100)

// ========================================
// ENHANCED BOUNTY SEEKER + ORB FVG
// ========================================
// 🎯 KEY IMPROVEMENTS:
//    ✅ More accurate SFP detection with multiple touch validation
//    ✅ Only Major/Strong SFPs shown (simplified)
//    ✅ Better Single Print detection with volume validation
//    ✅ Educational labels and legend for new traders
//    ✅ Improved visual hierarchy and color coding
//    ✅ Extended line management with proper cleanup
//    ✅ Better FVG detection with volume confirmation
//    ✅ Tooltips and descriptions
// ========================================

// === INPUT GROUPS ===
grpPivots = "📊 Major Pivot Detection"
grpSFPs = "🔴 Support/Resistance Lines (SFPs)"
grpSPs = "🔵 Single Print Lines"
grpORB = "📈 Opening Range Breakout (ORB)"
grpFVG = "💎 Fair Value Gaps (FVG)"
grpVisual = "🎨 Visual Settings"
grpEducation = "📚 Educational Tools"

// === PIVOT INPUTS ===
pivotLookback   = input.int(10, "Pivot Lookback Bars", minval=3, maxval=50, group=grpPivots, tooltip="How many bars to look back for pivot detection")
minVolumeMult   = input.float(1.0, "Min Volume Multiplier", minval=0.5, step=0.1, group=grpPivots, tooltip="Minimum volume (× avg) for valid pivot")
strongVolumeMult = input.float(1.5, "Strong Volume Multiplier", minval=1.0, step=0.1, group=grpPivots, tooltip="Volume threshold for 'strong' pivots")
atrMinDistMult  = input.float(0.2, "Min Pivot Distance (ATR×)", minval=0.1, step=0.05, group=grpPivots, tooltip="Minimum distance between pivots")

// === SFP INPUTS (Strong/Major Only) ===
showSFPs        = input.bool(true, "Show Major SFPs", group=grpSFPs, tooltip="Show only major SFPs (2+ touches or high volume)")
maxSFPs         = input.int(10, "Max SFP Lines", minval=1, maxval=30, group=grpSFPs, tooltip="Maximum number of SFP lines to display")
sfpLineWidth    = input.int(1, "SFP Line Width", minval=1, maxval=3, group=grpSFPs, tooltip="Width of SFP lines")
sfpOpacity      = input.int(60, "SFP Line Opacity", minval=0, maxval=100, group=grpSFPs, tooltip="Transparency (0=transparent, 100=opaque)")
minTouchesForStrong = input.int(2, "Min Touches for Strong SFP", minval=1, maxval=5, group=grpSFPs, tooltip="Number of price touches needed for 'Strong' classification")
sfpMergeDistance = input.float(0.5, "SFP Merge Distance %", minval=0.1, step=0.1, group=grpSFPs, tooltip="Merge SFPs within this % distance")

// === SINGLE PRINT INPUTS ===
showSPs         = input.bool(false, "Show Single Prints", group=grpSPs, tooltip="Display single print lines")
spLookback      = input.int(20, "Single Print Lookback", minval=5, maxval=100, group=grpSPs, tooltip="Bars to check for single prints")
maxSPs          = input.int(5, "Max Single Print Lines", minval=1, maxval=20, group=grpSPs)
spExtendBars    = input.int(0, "SP Line Extension (0=No Extension)", minval=0, maxval=50, group=grpSPs, tooltip="How far SP lines extend (0 for no extension)")
spVolumeMult    = input.float(1.2, "SP: Min Volume Multiplier", minval=1.0, step=0.1, group=grpSPs, tooltip="Minimum volume for valid single print")
spRequireSweep  = input.bool(true, "SP: Require Sweep", group=grpSPs, tooltip="Only show SPs that were swept")

// === ORB INPUTS ===
orbStartHour    = input.int(9, "ORB Start Hour", minval=0, maxval=23, group=grpORB, tooltip="Opening range start hour (exchange timezone)")
orbStartMinute  = input.int(30, "ORB Start Minute", minval=0, maxval=59, group=grpORB)
orbEndHour      = input.int(9, "ORB End Hour", minval=0, maxval=23, group=grpORB)
orbEndMinute    = input.int(45, "ORB End Minute", minval=0, maxval=59, group=grpORB)
orbTimeZone     = input.string("GMT-5", "Timezone", group=grpORB, tooltip="Exchange timezone (GMT-5 for US markets)")

// === FVG INPUTS ===
showFVGs        = input.bool(false, "Show Fair Value Gaps", group=grpFVG)
fvgVolumeMult   = input.float(0.8, "FVG: Min Volume Multiplier", minval=0.5, step=0.1, group=grpFVG, tooltip="Minimum volume for valid FVG")
maxFVGs         = input.int(10, "Max FVG Zones", minval=1, maxval=30, group=grpFVG)
fvgMergePercent = input.float(0.3, "FVG Merge Distance %", minval=0.1, step=0.1, group=grpFVG, tooltip="Merge FVGs within this % distance")

// === VISUAL INPUTS ===
showStrongPivots = input.bool(false, "Show Strong Pivots Only", group=grpVisual, tooltip="Show only strong bear/bull pivots (circles)")
showAllPivots = input.bool(false, "Show All Pivot Markers", group=grpVisual, tooltip="Show normal and fakeout pivots too")
showLegend      = input.bool(false, "Show Legend", group=grpVisual, tooltip="Display legend explaining all elements")
showLabels      = input.bool(false, "Show Educational Labels", group=grpVisual, tooltip="Add labels explaining key concepts")

// === LINE CUSTOMIZATION ===
grpLineStyle = "🎨 Line Customization"
sfpLineStyle = input.string("Dashed", "SFP Line Style", options=["Solid", "Dashed", "Dotted"], group=grpLineStyle)

// === ALERTS ===
grpAlerts = "🔔 Alert Settings"
alertOnStrongPivot = input.bool(true, "Alert: Strong Pivots", group=grpAlerts)
alertOnNormalPivot = input.bool(false, "Alert: Normal Pivots", group=grpAlerts)
alertOnFakeoutPivot = input.bool(false, "Alert: Fakeout Pivots", group=grpAlerts)
alertOnStrongSFP = input.bool(true, "Alert: Strong SFP Created", group=grpAlerts)
alertOnSFPUpdate = input.bool(false, "Alert: SFP Touch/Update", group=grpAlerts)
alertOnSP = input.bool(false, "Alert: Single Print", group=grpAlerts)
alertOnORB = input.bool(true, "Alert: ORB Break", group=grpAlerts)
alertOnFVG = input.bool(false, "Alert: FVG Created", group=grpAlerts)

// === EDUCATION INPUTS ===
showTooltips    = input.bool(true, "Enable Tooltips", group=grpEducation, tooltip="Hover tooltips for better understanding")

// === CALCULATIONS ===
volSMA = ta.sma(volume, 20)
atrPeriod = 14
atr = ta.atr(atrPeriod)
softPivotMinDist = atrMinDistMult * atr

// Store pivot history for touch counting
var line[] bearLines = array.new<line>()
var line[] bullLines = array.new<line>()
var float[] bearPrices = array.new<float>()
var float[] bullPrices = array.new<float>()
var int[] bearTouches = array.new<int>()
var int[] bullTouches = array.new<int>()
var int[] bearBars = array.new<int>()  // Creation bar
var int[] bullBars = array.new<int>()  // Creation bar
var int[] bearLastTouch = array.new<int>()  // Last touch bar (for preventing double counting)
var int[] bullLastTouch = array.new<int>()  // Last touch bar

var float lastPivotPrice = na

// === ENHANCED PIVOT DETECTION ===
majorPivotHigh = ta.pivothigh(high, pivotLookback, pivotLookback)
majorPivotLow  = ta.pivotlow(low, pivotLookback, pivotLookback)

priceRange = ta.highest(high, pivotLookback) - ta.lowest(low, pivotLookback)
lowVol = volume < volSMA * 0.7
smallBody = math.abs(close - open) < priceRange * 0.1

pivotHighFar = na(lastPivotPrice) or (not na(majorPivotHigh) and math.abs(majorPivotHigh - lastPivotPrice) > softPivotMinDist)
pivotLowFar  = na(lastPivotPrice) or (not na(majorPivotLow) and math.abs(majorPivotLow - lastPivotPrice) > softPivotMinDist)

isHighVol = volume > volSMA * minVolumeMult
isStrongVol = volume > volSMA * strongVolumeMult

plotHigh = not na(majorPivotHigh) and pivotHighFar and isHighVol
plotLow  = not na(majorPivotLow) and pivotLowFar and isHighVol
strongHigh = plotHigh and isStrongVol
strongLow  = plotLow and isStrongVol
normalHigh = plotHigh and not isStrongVol
normalLow  = plotLow and not isStrongVol

if plotHigh or plotLow
    lastPivotPrice := plotHigh ? majorPivotHigh : majorPivotLow

// Fakeout detection
fakeHigh = not na(majorPivotHigh) and lowVol and smallBody and pivotHighFar
fakeLow  = not na(majorPivotLow) and lowVol and smallBody and pivotLowFar

// === ENHANCED SFP LINE MANAGEMENT ===
// Function to check if price is near a stored level (for touch counting)
isNearLevel(price, storedPrice, mergePercent) =>
    math.abs(price - storedPrice) / storedPrice < mergePercent / 100

// Function to find and update touch count for a level
updateTouchCount(priceArray, touchArray, barsArray, price, mergePercent, barIdx) =>
    found = false
    for i = 0 to array.size(priceArray) - 1
        if isNearLevel(price, array.get(priceArray, i), mergePercent)
            // Update touch count
            oldTouches = array.get(touchArray, i)
            array.set(touchArray, i, oldTouches + 1)
            found := true
            break
    found

// Function to get SFP strength color (must be defined before use)
getSFPStrength(touches, isStrongVol, barsSince, minTouches) =>
    strength = 0
    if touches >= minTouches
        strength += 2
    else if touches >= 1
        strength += 1
    if isStrongVol
        strength += 1
        // High volume pivots start as "strong" even with 0 touches
        if touches == 0
            strength += 1
    // Age factor (newer is slightly better)
    if barsSince < 50
        strength += 1
    strength

// Function to convert style string to line style
getLineStyle(styleStr) =>
    styleStr == "Solid" ? line.style_solid : styleStr == "Dashed" ? line.style_dashed : line.style_dotted

// Function to determine if SFP should be shown (only strong/major SFPs)
getSFPDisplayInfo(strength, minTouches, touches, isStrongVol) =>
    isStrong = strength >= 3

    // Only show if it's a strong SFP and toggle is on
    shouldShow = isStrong and showSFPs

    [shouldShow]

// Check for touches on existing SFPs (optimized - only check when price moves significantly)
if showSFPs and (barstate.isconfirmed or barstate.islast)
    priceMove = math.abs(close - close[1]) / close[1]
    // Only check touches if price moved significantly (reduces unnecessary calculations)
    if priceMove > 0.0005  // 0.05% move threshold
        // Check bear lines (resistance) - price approaching from below
        if array.size(bearPrices) > 0
            for i = 0 to math.min(array.size(bearPrices) - 1, maxSFPs - 1)
                bearPrice = array.get(bearPrices, i)
                // Price touched or got very close (within 0.3%)
                touchDist = math.abs(high - bearPrice) / bearPrice
                if touchDist < 0.003 and high >= bearPrice * 0.997  // Only count if price got close from below
                    oldTouches = array.get(bearTouches, i)
                    // Prevent double counting (only increment once per bar)
                    lastTouchBar = i < array.size(bearLastTouch) ? array.get(bearLastTouch, i) : -1
                    if bar_index != lastTouchBar
                        array.set(bearTouches, i, oldTouches + 1)
                        // Update last touch bar tracking
                        if i >= array.size(bearLastTouch)
                            array.push(bearLastTouch, bar_index)
                        else
                            array.set(bearLastTouch, i, bar_index)
                        // Update line color based on new touch count (keep red for resistance)
                        creationBar = array.get(bearBars, i)
                        strength = getSFPStrength(array.get(bearTouches, i), false, bar_index - creationBar, minTouchesForStrong)
                        if i < array.size(bearLines)
                            // Only update if still strong, otherwise keep it red
                            if strength >= 3
                                line.set_color(array.get(bearLines, i), color.new(color.red, 100 - sfpOpacity))
                                line.set_width(array.get(bearLines, i), sfpLineWidth)

        // Check bull lines (support) - price approaching from above
        if array.size(bullPrices) > 0
            for i = 0 to math.min(array.size(bullPrices) - 1, maxSFPs - 1)
                bullPrice = array.get(bullPrices, i)
                touchDist = math.abs(low - bullPrice) / bullPrice
                if touchDist < 0.003 and low <= bullPrice * 1.003  // Only count if price got close from above
                    oldTouches = array.get(bullTouches, i)
                    lastTouchBar = i < array.size(bullLastTouch) ? array.get(bullLastTouch, i) : -1
                    if bar_index != lastTouchBar
                        array.set(bullTouches, i, oldTouches + 1)
                        // Update last touch bar tracking
                        if i >= array.size(bullLastTouch)
                            array.push(bullLastTouch, bar_index)
                        else
                            array.set(bullLastTouch, i, bar_index)
                        // Update line color based on new touch count (keep green for support)
                        creationBar = array.get(bullBars, i)
                        strength = getSFPStrength(array.get(bullTouches, i), false, bar_index - creationBar, minTouchesForStrong)
                        if i < array.size(bullLines)
                            // Only update if still strong, otherwise keep it green
                            if strength >= 3
                                line.set_color(array.get(bullLines, i), color.new(color.lime, 100 - sfpOpacity))
                                line.set_width(array.get(bullLines, i), sfpLineWidth)

// Create/update bear SFP lines
if plotHigh
    // Check if we should merge with existing level
    shouldMerge = false
    mergeIdx = -1
    if array.size(bearPrices) > 0
        for i = 0 to math.min(array.size(bearPrices) - 1, maxSFPs - 1)
            if isNearLevel(majorPivotHigh, array.get(bearPrices, i), sfpMergeDistance)
                shouldMerge := true
                mergeIdx := i
                break

    if not shouldMerge
        // Create new line - only show if strong
        strength = getSFPStrength(0, isStrongVol, 0, minTouchesForStrong)
        [shouldShow] = getSFPDisplayInfo(strength, minTouchesForStrong, 0, isStrongVol)

        if shouldShow
            // Use pivot high (which is the wick from pivotLookback bars ago), extend fully across chart
            pivotWickHigh = majorPivotHigh
            lineColor = color.new(color.red, 100 - sfpOpacity)
            lineWidth = sfpLineWidth

            // Create ray extending from pivot wick across entire chart
            l = line.new(x1=bar_index, y1=pivotWickHigh, x2=bar_index, y2=pivotWickHigh,
                         color=lineColor, style=getLineStyle(sfpLineStyle), width=lineWidth, extend=extend.right)

            array.unshift(bearLines, l)
            array.unshift(bearPrices, pivotWickHigh)
            array.unshift(bearTouches, 0)
            array.unshift(bearBars, bar_index)
            array.unshift(bearLastTouch, -1)  // Initialize last touch

            if array.size(bearLines) > maxSFPs
                line.delete(array.pop(bearLines))
                array.pop(bearPrices)
                array.pop(bearTouches)
                array.pop(bearBars)
                array.pop(bearLastTouch)

            // Alert on strong SFP creation
            if alertOnStrongSFP and strength >= 3
                alert("Strong SFP (Resistance) Created at " + str.tostring(majorPivotHigh), alert.freq_once_per_bar)
    else if mergeIdx >= 0 and mergeIdx < array.size(bearLines)
        // Update existing line position and color based on new touches
        mergeLine = array.get(bearLines, mergeIdx)
        mergePrice = array.get(bearPrices, mergeIdx)
        mergeTouches = array.get(bearTouches, mergeIdx)
        mergeBars = array.get(bearBars, mergeIdx)

        // Use the higher pivot wick high for resistance
        pivotWickHigh = majorPivotHigh
        newPrice = math.max(pivotWickHigh, mergePrice)
        array.set(bearPrices, mergeIdx, newPrice)

        // Update touches (increment if this is a new touch)
        if math.abs(pivotWickHigh - mergePrice) / mergePrice > 0.001
            mergeTouches := mergeTouches + 1
            array.set(bearTouches, mergeIdx, mergeTouches)

        strength = getSFPStrength(mergeTouches, isStrongVol, bar_index - mergeBars, minTouchesForStrong)
        [shouldShow] = getSFPDisplayInfo(strength, minTouchesForStrong, mergeTouches, isStrongVol)

        if shouldShow
            lineColor = color.new(color.red, 100 - sfpOpacity)
            lineWidth = sfpLineWidth

            // Update line to extend from current bar across chart
            line.set_xy1(mergeLine, bar_index, newPrice)
            line.set_xy2(mergeLine, bar_index, newPrice)
            line.set_extend(mergeLine, extend.right)
            line.set_color(mergeLine, lineColor)
            line.set_width(mergeLine, lineWidth)
            line.set_style(mergeLine, getLineStyle(sfpLineStyle))

            // Alert on SFP update
            if alertOnSFPUpdate
                alert("Major SFP Updated: Resistance at " + str.tostring(newPrice), alert.freq_once_per_bar)
        else
            // Hide line if toggle is off
            line.delete(mergeLine)

// Create/update bull SFP lines
if plotLow
    shouldMerge = false
    mergeIdx = -1
    if array.size(bullPrices) > 0
        for i = 0 to math.min(array.size(bullPrices) - 1, maxSFPs - 1)
            if isNearLevel(majorPivotLow, array.get(bullPrices, i), sfpMergeDistance)
                shouldMerge := true
                mergeIdx := i
                break

    if not shouldMerge
        strength = getSFPStrength(0, isStrongVol, 0, minTouchesForStrong)
        [shouldShow] = getSFPDisplayInfo(strength, minTouchesForStrong, 0, isStrongVol)

        if shouldShow
            // Use pivot low (which is the wick from pivotLookback bars ago), extend fully across chart
            pivotWickLow = majorPivotLow
            lineColor = color.new(color.lime, 100 - sfpOpacity)
            lineWidth = sfpLineWidth

            // Create ray extending from pivot wick across entire chart
            l = line.new(x1=bar_index, y1=pivotWickLow, x2=bar_index, y2=pivotWickLow,
                         color=lineColor, style=getLineStyle(sfpLineStyle), width=lineWidth, extend=extend.right)

            array.unshift(bullLines, l)
            array.unshift(bullPrices, pivotWickLow)
            array.unshift(bullTouches, 0)
            array.unshift(bullBars, bar_index)
            array.unshift(bullLastTouch, -1)  // Initialize last touch

            if array.size(bullLines) > maxSFPs
                line.delete(array.pop(bullLines))
                array.pop(bullPrices)
                array.pop(bullTouches)
                array.pop(bullBars)
                array.pop(bullLastTouch)

            // Alert on strong SFP creation
            if alertOnStrongSFP and strength >= 3
                alert("Strong SFP (Support) Created at " + str.tostring(majorPivotLow), alert.freq_once_per_bar)
    else if mergeIdx >= 0 and mergeIdx < array.size(bullLines)
        mergeLine = array.get(bullLines, mergeIdx)
        mergePrice = array.get(bullPrices, mergeIdx)
        mergeTouches = array.get(bullTouches, mergeIdx)
        mergeBars = array.get(bullBars, mergeIdx)

        // Use the lower pivot wick low for support
        pivotWickLow = majorPivotLow
        newPrice = math.min(pivotWickLow, mergePrice)
        array.set(bullPrices, mergeIdx, newPrice)

        if math.abs(pivotWickLow - mergePrice) / mergePrice > 0.001
            mergeTouches := mergeTouches + 1
            array.set(bullTouches, mergeIdx, mergeTouches)

        strength = getSFPStrength(mergeTouches, isStrongVol, bar_index - mergeBars, minTouchesForStrong)
        [shouldShow] = getSFPDisplayInfo(strength, minTouchesForStrong, mergeTouches, isStrongVol)

        if shouldShow
            lineColor = color.new(color.lime, 100 - sfpOpacity)
            lineWidth = sfpLineWidth

            // Update line to extend from current bar across chart
            line.set_xy1(mergeLine, bar_index, newPrice)
            line.set_xy2(mergeLine, bar_index, newPrice)
            line.set_extend(mergeLine, extend.right)
            line.set_color(mergeLine, lineColor)
            line.set_width(mergeLine, lineWidth)
            line.set_style(mergeLine, getLineStyle(sfpLineStyle))

            // Alert on SFP update
            if alertOnSFPUpdate
                alert("Major SFP Updated: Support at " + str.tostring(newPrice), alert.freq_once_per_bar)
        else
            // Hide line if toggle is off
            line.delete(mergeLine)

// === ENHANCED SINGLE PRINT DETECTION ===
var line[] spLines = array.new<line>()
var float[] spPrices = array.new<float>()
var bool[] spIsHigh = array.new<bool>()

// More accurate single print detection
for i = 1 to math.min(spLookback, bar_index)
    h = high[i]
    l = low[i]

    // Check if high is unique in lookback period
    hCount = 0
    hTouched = false
    for j = 1 to math.min(spLookback, bar_index)
        if math.abs(high[j] - h) / h < 0.001  // Within 0.1% tolerance
            hCount += 1
        // Check if it was swept
        if spRequireSweep and j < i and high[j] > h * 1.002
            hTouched := true

    // Check if low is unique in lookback period
    lCount = 0
    lTouched = false
    for j = 1 to math.min(spLookback, bar_index)
        if math.abs(low[j] - l) / l < 0.001
            lCount += 1
        if spRequireSweep and j < i and low[j] < l * 0.998
            lTouched := true

    // Valid single print high
    if hCount == 1 and volume[i] > volSMA[i] * spVolumeMult and (not spRequireSweep or hTouched)
        // Check if we already have this SP
        alreadyExists = false
        if array.size(spPrices) > 0
            for k = 0 to array.size(spPrices) - 1
                if math.abs(array.get(spPrices, k) - h) / h < 0.002
                    alreadyExists := true
                    break

        if not alreadyExists and showSPs
            spEndBar = spExtendBars > 0 ? (bar_index-i+spExtendBars) : bar_index-i
            lsp = line.new(x1=bar_index-i, y1=h, x2=spEndBar, y2=h,
                          color=color.new(color.blue, 10), style=line.style_dotted, width=1, extend=spExtendBars > 0 ? extend.right : extend.none)
            array.unshift(spLines, lsp)
            array.unshift(spPrices, h)
            array.unshift(spIsHigh, true)
            if array.size(spLines) > maxSPs
                line.delete(array.pop(spLines))
                array.pop(spPrices)
                array.pop(spIsHigh)

            // Alert on Single Print
            if alertOnSP
                alert("Single Print (High) at " + str.tostring(h), alert.freq_once_per_bar)

    // Valid single print low
    if lCount == 1 and volume[i] > volSMA[i] * spVolumeMult and (not spRequireSweep or lTouched)
        alreadyExists = false
        if array.size(spPrices) > 0
            for k = 0 to array.size(spPrices) - 1
                if math.abs(array.get(spPrices, k) - l) / l < 0.002
                    alreadyExists := true
                    break

        if not alreadyExists and showSPs
            spEndBar = spExtendBars > 0 ? (bar_index-i+spExtendBars) : bar_index-i
            lsp = line.new(x1=bar_index-i, y1=l, x2=spEndBar, y2=l,
                          color=color.new(color.blue, 10), style=line.style_dotted, width=1, extend=spExtendBars > 0 ? extend.right : extend.none)
            array.unshift(spLines, lsp)
            array.unshift(spPrices, l)
            array.unshift(spIsHigh, false)
            if array.size(spLines) > maxSPs
                line.delete(array.pop(spLines))
                array.pop(spPrices)
                array.pop(spIsHigh)

            // Alert on Single Print
            if alertOnSP
                alert("Single Print (Low) at " + str.tostring(l), alert.freq_once_per_bar)

// === PIVOT MARKERS ===
// Strong pivots (always shown if showStrongPivots is true)
plotchar(showStrongPivots and strongHigh ? majorPivotHigh : na, title="Strong Bear Pivot", char="●", location=location.abovebar, color=color.red, size=size.tiny)
plotchar(showStrongPivots and strongLow ? majorPivotLow : na, title="Strong Bull Pivot", char="●", location=location.belowbar, color=color.lime, size=size.tiny)
// Normal and fakeout pivots (only if showAllPivots is true)
plotchar(showAllPivots and normalHigh ? majorPivotHigh : na, title="Bear Pivot", char="×", location=location.abovebar, color=color.purple, size=size.tiny)
plotchar(showAllPivots and normalLow ? majorPivotLow : na, title="Bull Pivot", char="×", location=location.belowbar, color=color.white, size=size.tiny)
plotchar(showAllPivots and fakeHigh ? majorPivotHigh : na, title="Fakeout Pivot", char="×", location=location.belowbar, color=color.orange, size=size.tiny)
plotchar(showAllPivots and fakeLow ? majorPivotLow : na, title="Fakeout Pivot", char="×", location=location.abovebar, color=color.orange, size=size.tiny)

// === PIVOT ALERTS ===
if alertOnStrongPivot and strongHigh
    alert("Strong Bearish Pivot at " + str.tostring(majorPivotHigh), alert.freq_once_per_bar)
if alertOnStrongPivot and strongLow
    alert("Strong Bullish Pivot at " + str.tostring(majorPivotLow), alert.freq_once_per_bar)
if alertOnNormalPivot and normalHigh
    alert("Bearish Pivot at " + str.tostring(majorPivotHigh), alert.freq_once_per_bar)
if alertOnNormalPivot and normalLow
    alert("Bullish Pivot at " + str.tostring(majorPivotLow), alert.freq_once_per_bar)
if alertOnFakeoutPivot and fakeHigh
    alert("Fakeout Bearish Pivot at " + str.tostring(majorPivotHigh), alert.freq_once_per_bar)
if alertOnFakeoutPivot and fakeLow
    alert("Fakeout Bullish Pivot at " + str.tostring(majorPivotLow), alert.freq_once_per_bar)

// === ORB CALCULATION ===
sessionStart = timestamp(orbTimeZone, year, month, dayofmonth, 0, 0)
sessionEnd = timestamp(orbTimeZone, year, month, dayofmonth, 23, 59)
orbStart = timestamp(orbTimeZone, year, month, dayofmonth, orbStartHour, orbStartMinute)
orbEnd   = timestamp(orbTimeZone, year, month, dayofmonth, orbEndHour, orbEndMinute)

var float orbHigh = na
var float orbLow = na
var line orbHighLine = na
var line orbLowLine = na
var label orbHighLabel = na
var label orbLowLabel = na

timeReset = (na(time[1]) or (time[1] < sessionStart and time >= sessionStart))
if timeReset
    orbHigh := na
    orbLow := na
    // Always delete ORB lines (they're disabled)
    if not na(orbHighLine)
        line.delete(orbHighLine)
        orbHighLine := na
    if not na(orbLowLine)
        line.delete(orbLowLine)
        orbLowLine := na
    if not na(orbHighLabel)
        label.delete(orbHighLabel)
        orbHighLabel := na
    if not na(orbLowLabel)
        label.delete(orbLowLabel)
        orbLowLabel := na

// Delete any existing ORB lines on every bar (keep them removed)
if not na(orbHighLine)
    line.delete(orbHighLine)
    orbHighLine := na
if not na(orbLowLine)
    line.delete(orbLowLine)
    orbLowLine := na

if (time >= orbStart and time <= orbEnd)
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow  := na(orbLow)  ? low  : math.min(orbLow, low)

// ORB lines disabled - only SFPs shown
// if (time > orbEnd and not na(orbHigh) and not na(orbLow))
//     orbJustCreated = na(orbHighLine)
//     if na(orbHighLine)
//         orbHighLine := line.new(x1=bar_index, y1=orbHigh, x2=bar_index, y2=orbHigh,
//                                color=color.new(color.white, 51), width=2, extend=extend.right)
//         if showLabels
//             orbHighLabel := label.new(bar_index, orbHigh, "ORB High", color=na, textcolor=color.white, style=label.style_label_down, size=size.small)
//     else
//         line.set_x2(orbHighLine, bar_index)
//         line.set_y2(orbHighLine, orbHigh)
//
//     if na(orbLowLine)
//         orbLowLine := line.new(x1=bar_index, y1=orbLow, x2=bar_index, y2=orbLow,
//                               color=color.new(color.purple, 51), width=2, extend=extend.right)
//         if showLabels
//             orbLowLabel := label.new(bar_index, orbLow, "ORB Low", color=na, textcolor=color.purple, style=label.style_label_up, size=size.small)
//     else
//         line.set_x2(orbLowLine, bar_index)
//         line.set_y2(orbLowLine, orbLow)

    // ORB Break alerts (only if ORB data exists)
    if alertOnORB and time > orbEnd and not na(orbHigh) and not na(orbLow)
        if high > orbHigh
            alert("ORB High Breakout at " + str.tostring(high), alert.freq_once_per_bar)
        if low < orbLow
            alert("ORB Low Breakdown at " + str.tostring(low), alert.freq_once_per_bar)

// === ENHANCED FVG DETECTION ===
var line[] fvgLines = array.new<line>()
var box[] fvgBoxes = array.new<box>()
var float[] fvgHighs = array.new<float>()
var float[] fvgLows = array.new<float>()

pink = color.new(#FF69B4, 70)

if showFVGs and (time >= orbStart and time <= orbEnd)
    // Bullish FVG: gap up
    if high[1] < low and volume > volSMA * fvgVolumeMult
        fvgTop = high[1]
        fvgBottom = low
        // Check if this FVG overlaps with existing ones
        shouldMerge = false
        mergeIdx = -1
        if array.size(fvgHighs) > 0
            for i = 0 to array.size(fvgHighs) - 1
                existingTop = array.get(fvgHighs, i)
                existingBot = array.get(fvgLows, i)
                // Check for overlap
                if (fvgBottom <= existingTop and fvgTop >= existingBot)
                    shouldMerge := true
                    mergeIdx := i
                    break

        if not shouldMerge
            // Create new FVG
            fvgBox = box.new(left=bar_index-1, top=fvgTop, right=bar_index+maxFVGs*2, bottom=fvgBottom, border_color=pink, bgcolor=pink, extend=extend.right)
            array.unshift(fvgBoxes, fvgBox)
            array.unshift(fvgHighs, fvgTop)
            array.unshift(fvgLows, fvgBottom)
            if array.size(fvgBoxes) > maxFVGs
                box.delete(array.pop(fvgBoxes))
                array.pop(fvgHighs)
                array.pop(fvgLows)

            // Alert on FVG creation
            if alertOnFVG
                alert("Bullish FVG Created: " + str.tostring(fvgBottom) + " - " + str.tostring(fvgTop), alert.freq_once_per_bar)

    // Bearish FVG: gap down
    if low[1] > high and volume > volSMA * fvgVolumeMult
        fvgTop = low[1]
        fvgBottom = high
        shouldMerge = false
        mergeIdx = -1
        if array.size(fvgHighs) > 0
            for i = 0 to array.size(fvgHighs) - 1
                existingTop = array.get(fvgHighs, i)
                existingBot = array.get(fvgLows, i)
                if (fvgBottom <= existingTop and fvgTop >= existingBot)
                    shouldMerge := true
                    mergeIdx := i
                    break

        if not shouldMerge
            fvgBox = box.new(left=bar_index-1, top=fvgTop, right=bar_index+maxFVGs*2, bottom=fvgBottom, border_color=pink, bgcolor=pink, extend=extend.right)
            array.unshift(fvgBoxes, fvgBox)
            array.unshift(fvgHighs, fvgTop)
            array.unshift(fvgLows, fvgBottom)
            if array.size(fvgBoxes) > maxFVGs
                box.delete(array.pop(fvgBoxes))
                array.pop(fvgHighs)
                array.pop(fvgLows)

            // Alert on FVG creation
            if alertOnFVG
                alert("Bearish FVG Created: " + str.tostring(fvgBottom) + " - " + str.tostring(fvgTop), alert.freq_once_per_bar)

// === EDUCATIONAL LEGEND ===
var table legendTable = na

if showLegend and barstate.islast
    if na(legendTable)
        legendTable := table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 85), border_width=1)

    // Headers
    table.cell(legendTable, 0, 0, "Element", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))
    table.cell(legendTable, 1, 0, "Meaning", text_color=color.white, text_size=size.small, bgcolor=color.new(color.gray, 50))

    // SFP Lines (Major Only)
    table.cell(legendTable, 0, 1, "🔴 Red SFP", text_color=color.red, text_size=size.tiny)
    table.cell(legendTable, 1, 1, "Major Resistance (2+ touches or high volume)", text_color=color.white, text_size=size.tiny)

    table.cell(legendTable, 0, 2, "🟢 Green SFP", text_color=color.lime, text_size=size.tiny)
    table.cell(legendTable, 1, 2, "Major Support (2+ touches or high volume)", text_color=color.white, text_size=size.tiny)

    // Single Prints
    table.cell(legendTable, 0, 3, "🔵 Blue Dotted", text_color=color.blue, text_size=size.tiny)
    table.cell(legendTable, 1, 3, "Single Print Level", text_color=color.white, text_size=size.tiny)

    // ORB
    table.cell(legendTable, 0, 4, "⬜ White/Purple", text_color=color.white, text_size=size.tiny)
    table.cell(legendTable, 1, 4, "Opening Range High/Low", text_color=color.white, text_size=size.tiny)

    // FVG
    table.cell(legendTable, 0, 5, "💗 Pink Box", text_color=#FF69B4, text_size=size.tiny)
    table.cell(legendTable, 1, 5, "Fair Value Gap", text_color=color.white, text_size=size.tiny)

    // Pivots
    table.cell(legendTable, 0, 6, "● Red/Lime", text_color=color.red, text_size=size.tiny)
    table.cell(legendTable, 1, 6, "Strong Pivot (High Vol)", text_color=color.white, text_size=size.tiny)

    table.cell(legendTable, 0, 9, "× Purple/White", text_color=color.purple, text_size=size.tiny)
    table.cell(legendTable, 1, 9, "Normal Pivot", text_color=color.white, text_size=size.tiny)

    table.cell(legendTable, 0, 10, "× Orange", text_color=color.orange, text_size=size.tiny)
    table.cell(legendTable, 1, 10, "Fakeout Pivot", text_color=color.white, text_size=size.tiny)

    // Tip
    table.cell(legendTable, 0, 11, "💡 Tip", text_color=color.yellow, text_size=size.tiny, bgcolor=color.new(color.yellow, 90))
    table.cell(legendTable, 1, 11, "Strong SFPs = More Reliable!", text_color=color.black, text_size=size.tiny, bgcolor=color.new(color.yellow, 90))
