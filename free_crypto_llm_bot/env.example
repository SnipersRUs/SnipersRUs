# Discord Bot Configuration
# Get your Discord bot token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Ollama LLM Configuration
# Default: http://localhost:11434 (if running locally)
# Make sure Ollama is installed and running: https://ollama.com
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Alternative models: llama3, mistral, codellama, etc.
# Run: ollama pull mistral (or ollama pull llama3)

# Etherscan API (Free Tier)
# Get your free API key from: https://etherscan.io/apis
# Free tier: 5 calls/second, 100,000 calls/day
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# CoinGecko API (Optional - Free Tier)
# Get your free API key from: https://www.coingecko.com/en/api
# Without API key: 10-50 calls/minute (public API)
# With free API key: 50 calls/minute
COINGECKO_API_KEY=your_coingecko_api_key_here

# Solana RPC (Optional)
# Default: Public mainnet endpoint
# You can use a custom RPC endpoint if you have one
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Optional: Custom Discord Channel ID for startup notifications
# DISCORD_CHANNEL_ID=your_channel_id_here



