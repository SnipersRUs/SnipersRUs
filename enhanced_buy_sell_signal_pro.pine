//@version=6
indicator("Enhanced Buy/Sell Signal Pro", shorttitle="EBSS Pro", overlay=true, max_boxes_count=500, max_lines_count=500)

// ──────────────────────────────────────────────────────────────────────
// INPUT SETTINGS
// ──────────────────────────────────────────────────────────────────────
// Trend Settings
ma_fast_length = input.int(12, title="Fast MA Length", minval=1)
ma_slow_length = input.int(26, title="Slow MA Length", minval=1)
trend_threshold = input.float(0.5, title="Trend Strength Threshold", minval=0.1, maxval=2.0, step=0.1)

// Momentum Settings
rsi_length = input.int(14, title="RSI Length", minval=1)
rsi_oversold = input.int(30, title="RSI Oversold Level", minval=1, maxval=50)
rsi_overbought = input.int(70, title="RSI Overbought Level", minval=50, maxval=100)

// Volume Analysis
volume_ma_length = input.int(20, title="Volume MA Length", minval=1)
volume_multiplier = input.float(1.5, title="Volume Spike Multiplier", minval=1.0, maxval=5.0, step=0.1)

// Volatility & ATR
atr_length = input.int(14, title="ATR Length", minval=1)
atr_multiplier = input.float(2.0, title="ATR Stop Loss Multiplier", minval=0.5, maxval=5.0, step=0.1)

// Advanced Features
use_smart_volume = input.bool(true, title="Use Smart Volume Analysis")
use_liquidity_filter = input.bool(true, title="Use Liquidity Filter")
liquidity_threshold = input.float(2.0, title="Liquidity Spike Threshold", minval=1.0, maxval=5.0, step=0.1)

// Signal Settings
use_trend_filter = input.bool(true, title="Use Trend Filter")
use_volume_confirmation = input.bool(true, title="Use Volume Confirmation")
use_atr_stops = input.bool(true, title="Use ATR-Based Stops")
use_divergence_filter = input.bool(true, title="Use Divergence Filter")

// ──────────────────────────────────────────────────────────────────────
// CALCULATIONS
// ──────────────────────────────────────────────────────────────────────
// Moving Averages
ma_fast = ta.ema(close, ma_fast_length)
ma_slow = ta.ema(close, ma_slow_length)
ma_trend = ma_fast > ma_slow ? 1 : -1

// RSI
rsi = ta.rsi(close, rsi_length)
rsi_bullish = rsi > rsi_oversold and rsi[1] <= rsi_oversold
rsi_bearish = rsi < rsi_overbought and rsi[1] >= rsi_overbought

// Enhanced Volume Analysis
volume_ma = ta.sma(volume, volume_ma_length)
volume_spike = volume > volume_ma * volume_multiplier

// Smart Volume Analysis
rangePU = high - low
buyVolume = close < open ? volume * (high - close) / math.max(rangePU, 0.001) : volume * (close - low) / math.max(rangePU, 0.001)
sellVolume = volume - buyVolume
delta = buyVolume - sellVolume
var float cvd = 0
cvd += delta
cvdSmoothed = ta.ema(cvd, 5)
cvdTrend = cvdSmoothed > cvdSmoothed[1]

// Liquidity Analysis
volumeM = volume / 1e6
liqRawM = volumeM * rangePU
tickMove = math.abs(close - close[1])
tickVolume = tickMove > 0 ? volume / tickMove : volume
liqEnhancedM = (liqRawM * 0.7) + ((tickVolume / 1e6) * 0.3)
liqMean = ta.sma(liqEnhancedM, 50)
liqSpike = liqEnhancedM > liqMean * liquidity_threshold

// ATR for Dynamic Stops
atr = ta.atr(atr_length)
atr_stop_long = close - atr * atr_multiplier
atr_stop_short = close + atr * atr_multiplier

// Divergence Detection
pivotHigh = ta.pivothigh(high, 10, 10)
pivotLow = ta.pivotlow(low, 10, 10)
bearish_div = not na(pivotHigh) and rsi < rsi[3]
bullish_div = not na(pivotLow) and rsi > rsi[3]

// ──────────────────────────────────────────────────────────────────────
// SIGNAL GENERATION
// ──────────────────────────────────────────────────────────────────────
// Buy Conditions
buy_condition_1 = rsi_bullish
buy_condition_2 = use_trend_filter ? ma_trend > 0 : true
buy_condition_3 = use_volume_confirmation ? volume_spike : true
buy_condition_4 = use_smart_volume ? cvdTrend : true
buy_condition_5 = use_liquidity_filter ? liqSpike : true
buy_condition_6 = use_divergence_filter ? bullish_div : true

// Sell Conditions
sell_condition_1 = rsi_bearish
sell_condition_2 = use_trend_filter ? ma_trend < 0 : true
sell_condition_3 = use_volume_confirmation ? volume_spike : true
sell_condition_4 = use_smart_volume ? not cvdTrend : true
sell_condition_5 = use_liquidity_filter ? liqSpike : true
sell_condition_6 = use_divergence_filter ? bearish_div : true

// Generate Signals with Weighted Scoring
buy_score = 0.0
sell_score = 0.0

buy_score := buy_condition_1 ? buy_score + 2 : buy_score
buy_score := buy_condition_2 ? buy_score + 1.5 : buy_score
buy_score := buy_condition_3 ? buy_score + 1 : buy_score
buy_score := buy_condition_4 ? buy_score + 1 : buy_score
buy_score := buy_condition_5 ? buy_score + 0.5 : buy_score
buy_score := buy_condition_6 ? buy_score + 1.5 : buy_score

sell_score := sell_condition_1 ? sell_score + 2 : sell_score
sell_score := sell_condition_2 ? sell_score + 1.5 : sell_score
sell_score := sell_condition_3 ? sell_score + 1 : sell_score
sell_score := sell_condition_4 ? sell_score + 1 : sell_score
sell_score := sell_condition_5 ? sell_score + 0.5 : sell_score
sell_score := sell_condition_6 ? sell_score + 1.5 : sell_score

buy_signal = buy_score >= 4.0
sell_signal = sell_score >= 4.0

// Track Active Positions
var bool in_long_position = false
var bool in_short_position = false
var float stop_loss_price = na

// Update Position State
if buy_signal and not in_long_position
    in_long_position := true
    in_short_position := false
    stop_loss_price := use_atr_stops ? atr_stop_long : na
else if sell_signal and not in_short_position
    in_long_position := false
    in_short_position := true
    stop_loss_price := use_atr_stops ? atr_stop_short : na

// Exit Conditions (for ATR stops)
exit_long = in_long_position and close < stop_loss_price
exit_short = in_short_position and close > stop_loss_price

if exit_long or exit_short
    in_long_position := false
    in_short_position := false
    stop_loss_price := na

// ──────────────────────────────────────────────────────────────────────
// PLOTTING
// ──────────────────────────────────────────────────────────────────────
// Moving Averages
plot(ma_fast, color=color.new(color.blue, 0), title="Fast MA", linewidth=2)
plot(ma_slow, color=color.new(color.orange, 0), title="Slow MA", linewidth=2)

// Buy/Sell Signals with Strength Visualization
plotshape(buy_signal and buy_score >= 5, style=shape.triangleup, location=location.belowbar,
          color=color.new(color.green, 0), size=size.normal, title="Strong Buy Signal")
plotshape(buy_signal and buy_score < 5, style=shape.circle, location=location.belowbar,
          color=color.new(color.lime, 0), size=size.small, title="Weak Buy Signal")
plotshape(sell_signal and sell_score >= 5, style=shape.triangledown, location=location.abovebar,
          color=color.new(color.red, 0), size=size.normal, title="Strong Sell Signal")
plotshape(sell_signal and sell_score < 5, style=shape.circle, location=location.abovebar,
          color=color.new(color.orange, 0), size=size.small, title="Weak Sell Signal")

// Stop Loss Lines
plot(use_atr_stops and in_long_position ? stop_loss_price : na,
     color=color.new(color.red, 50), style=plot.style_line, linewidth=1, title="Long Stop Loss")
plot(use_atr_stops and in_short_position ? stop_loss_price : na,
     color=color.new(color.green, 50), style=plot.style_line, linewidth=1, title="Short Stop Loss")

// Background Colors for Trend
bgcolor(use_trend_filter and ma_trend > 0 ? color.new(color.green, 95) : na, title="Bullish Trend")
bgcolor(use_trend_filter and ma_trend < 0 ? color.new(color.red, 95) : na, title="Bearish Trend")

// ──────────────────────────────────────────────────────────────────────
// ALERTS
// ──────────────────────────────────────────────────────────────────────
alertcondition(buy_signal and buy_score >= 5, title="Strong Buy Signal", message="EBSS Pro: Strong Buy Signal Detected (Score: {{plot_0}})")
alertcondition(buy_signal and buy_score < 5, title="Weak Buy Signal", message="EBSS Pro: Weak Buy Signal Detected (Score: {{plot_0}})")
alertcondition(sell_signal and sell_score >= 5, title="Strong Sell Signal", message="EBSS Pro: Strong Sell Signal Detected (Score: {{plot_0}})")
alertcondition(sell_signal and sell_score < 5, title="Weak Sell Signal", message="EBSS Pro: Weak Sell Signal Detected (Score: {{plot_0}})")
alertcondition(exit_long, title="Long Position Exit", message="EBSS Pro: Long Position Exited via Stop Loss")
alertcondition(exit_short, title="Short Position Exit", message="EBSS Pro: Short Position Exited via Stop Loss")
