//@version=6
indicator("Vector Sniper Pro | Simplified", shorttitle="VSniperSim", overlay=true, max_labels_count=300, max_boxes_count=200)

// ───────── Inputs

group_core = "🎯 Core"

atrLen   = input.int(14, "ATR Period", group=group_core, minval=5)

volLen   = input.int(20, "Volume Period", group=group_core, minval=5)

trZThr   = input.float(1.2, "Volatility Z-Score", group=group_core, step=0.1)

volZThr  = input.float(1.0, "Volume Z-Score",    group=group_core, step=0.1)

extMult  = input.float(1.8, "Extreme Multiplier",group=group_core, step=0.1)

group_confirm = "✅ Vector Filters"

minBodyPct = input.int(55, "Min Body %", group=group_confirm, minval=1, maxval=100)

lbBreak    = input.int(5, "Structure Break (bars)", group=group_confirm, minval=1)

useBreak   = input.bool(true, "Require Structure Break", group=group_confirm)

useTrap    = input.bool(true, "Detect Traps", group=group_confirm)

group_pre = "🔮 Pre-Signal Filter (Noise Control)"

preMinScore   = input.int(4, "Min score (0–7)", group=group_pre, minval=1, maxval=7)

persistN      = input.int(2, "Must occur N bars", group=group_pre, minval=1, maxval=5)

persistWindow = input.int(4, "Within last M bars", group=group_pre, minval=1, maxval=10)

cooldownBars  = input.int(6, "Cooldown after pre-signal (bars)", group=group_pre, minval=0, maxval=100)

conflictLock  = input.int(4, "Hysteresis vs opposite (bars)", group=group_pre, minval=0, maxval=20)

useVWAP       = input.bool(true, "Require VWAP side alignment", group=group_pre)

useEMA        = input.bool(true, "Require EMA trend alignment",  group=group_pre)

emaLen        = input.int(50, "EMA Length", group=group_pre, minval=5)

useHTF        = input.bool(false, "Use HTF confluence", group=group_pre)

htf           = input.timeframe("60", "HTF", group=group_pre)

group_style = "🎨 Visuals"

colorizeCandles = input.bool(true, "Color Candles", group=group_style)

showMarks       = input.bool(true, "Show markers (extreme/exhaustion)", group=group_style)

// ───────── Helpers

f_z(src, len) =>

    _ma = ta.sma(src, len)

    _sd = ta.stdev(src, len)

    _sd == 0.0 ? 0.0 : (src - _ma) / _sd

// ───────── Core calcs

atr1  = ta.atr(1)

atr10 = ta.atr(10)

atr14 = ta.atr(14)

trZ   = f_z(atr1, atrLen)

volZ  = f_z(volume, volLen)

rng   = math.max(high - low, 1e-10)

body  = math.abs(close - open)

bodyPct = (body/rng)*100.0

avgVol   = ta.sma(volume, 20)

volRatio = volume / math.max(avgVol,1e-10)

vwap     = ta.vwap

ema      = ta.ema(close, emaLen)

emaUp    = ema > ema[1]

emaDn    = ema < ema[1]

vUp      = vwap > vwap[1]

vDn      = vwap < vwap[1]

// HTF bias (boolean series)

htfBull = useHTF ? request.security(syminfo.tickerid, htf, close) > request.security(syminfo.tickerid, htf, ta.ema(close, emaLen)) : true

htfBear = useHTF ? request.security(syminfo.tickerid, htf, close) < request.security(syminfo.tickerid, htf, ta.ema(close, emaLen)) : true

// Delta volume approximation

bullVol = volume * (close - low)  / rng

bearVol = volume * (high  - close)/ rng

delta   = bullVol - bearVol

deltaRatio = delta / math.max(volume, 1e-10)

// Structure

prevHighN = ta.highest(high, lbBreak)[1]

prevLowN  = ta.lowest(low,  lbBreak)[1]

bullBreak = high > prevHighN

bearBreak = low  < prevLowN

// Traps

bearTrap = useTrap and low  < low[1] and low  < low[2] and close > high[1]

bullTrap = useTrap and high > high[1] and high > high[2] and close < low[1]

// Base vectors

baseBull = (close > open) and (trZ >= trZThr) and (volZ >= volZThr) and (bodyPct >= minBodyPct) and (deltaRatio > 0.2)

baseBear = (close < open) and (trZ >= trZThr) and (volZ >= volZThr) and (bodyPct >= minBodyPct) and (deltaRatio < -0.2)

bullCond = (baseBull and (not useBreak or bullBreak)) or bearTrap

bearCond = (baseBear and (not useBreak or bearBreak)) or bullTrap

extBull = bullCond and trZ >= trZThr*extMult and volZ >= volZThr*extMult

extBear = bearCond and trZ >= trZThr*extMult and volZ >= volZThr*extMult

// ───────── Smart-money hints used only for PRE score

lowest3   = ta.lowest(low, 3)

highest3  = ta.highest(high,3)

spring    = (low < lowest3[1])   and (close > lowest3[1])   and (volRatio > 1.0)

upthrust  = (high > highest3[1]) and (close < highest3[1])  and (volRatio > 1.0)

noSupply  = (close > close[1]) and (volume < volume[1]) and (rng < atr10*0.7)

noDemand  = (close < close[1]) and (volume < volume[1]) and (rng < atr10*0.7)

imbBull = deltaRatio > 0.25

imbBear = deltaRatio < -0.25

nearBullBreak = math.abs(close - prevHighN) <= atr14*0.3

nearBearBreak = math.abs(close - prevLowN)  <= atr14*0.3

bullSideOK = (not useVWAP or (close > vwap and vUp)) and (not useEMA or emaUp) and htfBull

bearSideOK = (not useVWAP or (close < vwap and vDn)) and (not useEMA or emaDn) and htfBear

// ───────── Score + Persistence + Cooldown

bullScore = ((spring?1:0) + (noSupply?1:0) + (imbBull?1:0) + (volRatio > 1.2 ? 1:0) + (bullSideOK?1:0) + (nearBullBreak?1:0) + (close>open?1:0))

bearScore = ((upthrust?1:0) + (noDemand?1:0) + (imbBear?1:0) + (volRatio > 1.2 ? 1:0) + (bearSideOK?1:0) + (nearBearBreak?1:0) + (close<open?1:0))

preBullRaw = bullScore >= preMinScore

preBearRaw = bearScore >= preMinScore

// Rolling sums via cumulative

bullRawNum = preBullRaw ? 1 : 0

bearRawNum = preBearRaw ? 1 : 0

bullCum = ta.cum(bullRawNum)

bearCum = ta.cum(bearRawNum)

recentBull = bullCum - nz(bullCum[persistWindow], 0)

recentBear = bearCum - nz(bearCum[persistWindow], 0)

preBullPersist = recentBull >= persistN

preBearPersist = recentBear >= persistN

var int lastPreBull = na

var int lastPreBear = na

canBull = (na(lastPreBull) or bar_index - lastPreBull > cooldownBars) and (na(lastPreBear) or bar_index - lastPreBear > conflictLock)

canBear = (na(lastPreBear) or bar_index - lastPreBear > cooldownBars) and (na(lastPreBull) or bar_index - lastPreBull > conflictLock)

preBull = preBullPersist and canBull

preBear = preBearPersist and canBear

lastPreBull := preBull ? bar_index : lastPreBull

lastPreBear := preBear ? bar_index : lastPreBear

// ───────── Confirmed Trend Change & Reversal Detection

// Track what was active on previous bars (check last 5 bars for more reliable detection)
prevWasBullish = (bullCond[1] or extBull[1] or preBull[1]) or (bullCond[2] or extBull[2] or preBull[2]) or (bullCond[3] or extBull[3] or preBull[3]) or (bullCond[4] or extBull[4] or preBull[4]) or (bullCond[5] or extBull[5] or preBull[5])
prevWasBearish = (bearCond[1] or extBear[1] or preBear[1]) or (bearCond[2] or extBear[2] or preBear[2]) or (bearCond[3] or extBear[3] or preBear[3]) or (bearCond[4] or extBear[4] or preBear[4]) or (bearCond[5] or extBear[5] or preBear[5])

// Also check EMA/VWAP trend direction changes for more reliable detection
emaWasUp = ema[1] > ema[2]
emaWasDn = ema[1] < ema[2]
vwapWasUp = vwap[1] > vwap[2]
vwapWasDn = vwap[1] < vwap[2]

// Detect reversals - transitioning from opposite trend
reversalBull = (prevWasBearish or (emaWasDn and vwapWasDn)) and (bullCond or extBull)
reversalBear = (prevWasBullish or (emaWasUp and vwapWasUp)) and (bearCond or extBear)

// Confirmed trend changes (stronger signals - white for bull, solid purple for bear)
// Confirmed = extreme signal on reversal OR strong reversal with good body/volume
confirmedBullTrend = reversalBull and (extBull or (bullCond and bodyPct >= minBodyPct and volRatio >= 1.2))
confirmedBearTrend = reversalBear and (extBear or (bearCond and bodyPct >= minBodyPct and volRatio >= 1.2))

// Regular reversals (outlined - darker green/purple) - any reversal that's not confirmed
regularReversalBull = reversalBull and not confirmedBullTrend
regularReversalBear = reversalBear and not confirmedBearTrend

// ───────── Color System

clrBull   = color.new(#00ff00, 0) // neon green vector bull
clrBear   = color.new(#ff0000, 0) // red vector bear
clrPreB   = color.new(#1e90ff, 0) // blue pre-bull
clrPreS   = color.new(#ffa500, 0) // orange pre-bear
clrConfirmedBull = color.new(#ffffff, 0) // white for confirmed bull trend change
clrConfirmedBear = color.new(#800080, 0) // solid purple for confirmed bear trend change
clrReversalBull = color.new(#006400, 85) // darker green outlined for bull reversal
clrReversalBear = color.new(#4b0082, 85) // darker purple outlined for bear reversal
clrNeutral = color.new(#808080, 70) // grey for neutral

paint =
     confirmedBullTrend ? clrConfirmedBull :  // White for confirmed bull trend change
     confirmedBearTrend ? clrConfirmedBear :  // Solid purple for confirmed bear trend change
     regularReversalBull ? clrReversalBull :  // Outlined darker green for bull reversal
     regularReversalBear ? clrReversalBear :  // Outlined darker purple for bear reversal
     extBull or bullCond ? clrBull :  // Neon green for regular bull signals
     extBear or bearCond ? clrBear :  // Red for regular bear signals
     preBull ? clrPreB :
     preBear ? clrPreS :
     clrNeutral

barcolor(colorizeCandles ? paint : na)

// ───────── Minimal markers (optional)

plotshape(showMarks and extBull, title="Extreme Bull", style=shape.diamond, location=location.belowbar, color=color.new(clrBull,0), size=size.small)

plotshape(showMarks and extBear, title="Extreme Bear", style=shape.diamond, location=location.abovebar, color=color.new(clrBear,0), size=size.small)

plotshape(showMarks and preBull, title="Pre-Bull", style=shape.triangleup, location=location.belowbar, color=clrPreB, size=size.tiny)

plotshape(showMarks and preBear, title="Pre-Bear", style=shape.triangledown, location=location.abovebar, color=clrPreS, size=size.tiny)

// ───────── Alerts

alertcondition(bullCond, "🟢 Bull Vector", "BULL VECTOR: {{ticker}} @ {{close}}")

alertcondition(bearCond, "🔴 Bear Vector", "BEAR VECTOR: {{ticker}} @ {{close}}")

alertcondition(extBull,  "🚀 Extreme Bull", "EXTREME BULL: {{ticker}} @ {{close}}")

alertcondition(extBear,  "🔥 Extreme Bear", "EXTREME BEAR: {{ticker}} @ {{close}}")

alertcondition(preBull,  "📘 Pre-Bull (filtered)", "PRE-BULL: {{ticker}} @ {{close}}")

alertcondition(preBear,  "📙 Pre-Bear (filtered)", "PRE-BEAR: {{ticker}} @ {{close}}")

alertcondition(confirmedBullTrend, "⚪ Confirmed Bull Trend Change", "CONFIRMED BULL TREND CHANGE: {{ticker}} @ {{close}}")

alertcondition(confirmedBearTrend, "🟣 Confirmed Bear Trend Change", "CONFIRMED BEAR TREND CHANGE: {{ticker}} @ {{close}}")

alertcondition(regularReversalBull, "🟢 Bull Reversal", "BULL REVERSAL: {{ticker}} @ {{close}}")

alertcondition(regularReversalBear, "🟣 Bear Reversal", "BEAR REVERSAL: {{ticker}} @ {{close}}")
