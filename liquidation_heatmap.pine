// @version=6
// Liquidation Heatmap Indicator
// Tracks historical liquidity zones and removes them when cleared
// Shows where orders/liquidity have been sitting and when they get hit

indicator(title="Liquidation Heatmap", shorttitle="LiqHeatmap", overlay=true, max_boxes_count=2000, max_lines_count=500)

// ============================================================================
// INPUTS
// ============================================================================
lookback_period = input.int(200, "Lookback Period", minval=50, maxval=1000, group="Settings")
price_bins = input.int(150, "Price Bins", minval=50, maxval=300, group="Settings")
min_volume_threshold = input.float(1.5, "Min Volume Threshold", minval=1.0, maxval=5.0, step=0.1, group="Settings")
volume_multiplier = input.float(2.0, "Volume Multiplier", minval=1.0, maxval=10.0, step=0.1, group="Settings")
decay_factor = input.float(0.995, "Decay Factor", minval=0.9, maxval=0.999, step=0.001, group="Settings")
clearance_threshold = input.float(0.3, "Clearance Threshold %", minval=0.1, maxval=1.0, step=0.1, group="Settings", tooltip="How much price must move through zone to clear it")

// Display options
show_heatmap = input.bool(true, "Show Heatmap", group="Display")
show_cleared_zones = input.bool(false, "Show Cleared Zones (Faded)", group="Display")
heatmap_opacity = input.int(70, "Heatmap Opacity", minval=0, maxval=100, group="Display")
heatmap_width = input.int(100, "Heatmap Width (bars)", minval=20, maxval=500, group="Display")
position = input.string("Left", "Position", options=["Left", "Right"], group="Display")

// Color settings
color_bullish = input.color(color.new(color.red, 0), "Long Liquidations (Above Price)", group="Colors")
color_bearish = input.color(color.new(color.blue, 0), "Short Liquidations (Below Price)", group="Colors")
color_neutral = input.color(color.new(color.yellow, 0), "Neutral Zone", group="Colors")
color_cleared = input.color(color.new(color.gray, 80), "Cleared Zones", group="Colors")

// ============================================================================
// DATA STRUCTURES
// ============================================================================

// Store liquidity zones: price level, volume, cleared status, bar created
var array<float> zone_prices = array.new<float>()
var array<float> zone_volumes = array.new<float>()
var array<bool> zone_cleared = array.new<bool>()
var array<int> zone_bars = array.new<int>()

// Track price range for binning
var float price_min = na
var float price_max = na
var float price_step = na

// ============================================================================
// CALCULATIONS
// ============================================================================

// Update price range - call ta functions on every bar for consistency
current_min = ta.lowest(low, lookback_period)
current_max = ta.highest(high, lookback_period)

if barstate.isfirst
    price_min := current_min
    price_max := current_max
    // Ensure minimum range to avoid division by zero
    if price_max <= price_min
        price_max := price_min + (price_min * 0.01)  // 1% minimum range
    price_step := (price_max - price_min) / price_bins
else
    if current_min < price_min
        price_min := current_min
    if current_max > price_max
        price_max := current_max
    // Ensure minimum range
    if price_max <= price_min
        price_max := price_min + (price_min * 0.01)
    price_step := (price_max - price_min) / price_bins

// Round price to nearest bin
round_to_bin(price) =>
    math.round((price - price_min) / price_step) * price_step + price_min

// Check if a zone has been cleared (price swept through it)
// Calculate volume and ATR on every bar for consistency
avg_volume = ta.sma(volume, 20)
current_atr = ta.atr(14)

check_zone_cleared(zone_price, zone_volume) =>
    // Check if price has moved through this zone
    price_touched = (low <= zone_price and high >= zone_price)

    if price_touched
        // Check if there was significant volume (liquidity cleared)
        // Use a more lenient check - any significant volume when price touches zone
        volume_spike = volume > avg_volume * (volume_multiplier * 0.7)
        price_move = math.abs(high - low) > current_atr * 0.3

        // Also check if price moved significantly away from zone after touching
        moved_away = math.abs(close - zone_price) > price_step * 2

        (volume_spike and price_move) or moved_away
    else
        false

// Add or update liquidity zone
update_liquidity_zones() =>
    // Ensure we have valid price range first
    if not na(price_step) and price_step > 0 and not na(price_min) and not na(price_max)
        // Process current bar's price action
        bar_high_bin = round_to_bin(high)
        bar_low_bin = round_to_bin(low)
        bar_close_bin = round_to_bin(close)

        // Add volume to price levels where price traded
        levels_to_update = array.new<float>()
        volumes_to_add = array.new<float>()

        // Create bins for this bar's range - simplified approach
        // Calculate bin indices directly from price
        close_bin_idx = math.round((close - price_min) / price_step)
        high_bin_idx = math.round((high - price_min) / price_step)
        low_bin_idx = math.round((low - price_min) / price_step)

        start_bin = math.min(low_bin_idx, close_bin_idx - 2)
        end_bin = math.max(high_bin_idx, close_bin_idx + 2)

        // Ensure valid range
        if start_bin > end_bin
            temp = start_bin
            start_bin := end_bin
            end_bin := temp

        bin_count = end_bin - start_bin + 1
        if bin_count > 0
            for bin_idx = start_bin to end_bin
                if bin_idx >= 0 and bin_idx < price_bins
                    bin_price = price_min + (bin_idx * price_step)
                    // Check if this bin is within the bar's price range
                    if bin_price >= low and bin_price <= high
                        // Calculate volume contribution (more weight to close price)
                        distance_from_close = math.abs(bin_price - close)
                        weight = 1.0 - math.min(1.0, distance_from_close / (price_step * 5))
                        // Distribute volume - give more to bins near close
                        volume_contribution = volume * weight * (1.5 / math.max(1, bin_count))

                        array.push(levels_to_update, bin_price)
                        array.push(volumes_to_add, volume_contribution)

        // Update or create zones - only if we have levels to update
        if array.size(levels_to_update) > 0
            for i = 0 to array.size(levels_to_update) - 1
                level = array.get(levels_to_update, i)
                vol_to_add = array.get(volumes_to_add, i)

                // Find existing zone at this level (within price_step tolerance)
                zone_found = false
                for j = 0 to array.size(zone_prices) - 1
                    existing_price = array.get(zone_prices, j)
                    if math.abs(existing_price - level) < price_step * 0.5
                        // Update existing zone
                        existing_vol = array.get(zone_volumes, j)
                        is_cleared = array.get(zone_cleared, j)

                        if not is_cleared
                            // Apply decay and add new volume
                            decayed_vol = existing_vol * decay_factor
                            new_vol = decayed_vol + vol_to_add
                            array.set(zone_volumes, j, new_vol)
                            zone_found := true
                            break

                // Create new zone if not found
                if not zone_found
                    array.push(zone_prices, level)
                    array.push(zone_volumes, vol_to_add)
                    array.push(zone_cleared, false)
                    array.push(zone_bars, bar_index)

    // Check for cleared zones - only if we have zones
    if array.size(zone_prices) > 0
        for i = 0 to array.size(zone_prices) - 1
            zone_price = array.get(zone_prices, i)
            zone_vol = array.get(zone_volumes, i)
            is_cleared = array.get(zone_cleared, i)

            if not is_cleared
                if check_zone_cleared(zone_price, zone_vol)
                    array.set(zone_cleared, i, true)

    // Remove very old cleared zones to manage memory
    if array.size(zone_prices) > 500
        // Keep only recent zones - work backwards to avoid index issues
        i = array.size(zone_prices) - 1
        while i >= 0
            zone_bar = array.get(zone_bars, i)
            is_cleared = array.get(zone_cleared, i)
            // Remove if old and cleared
            if (bar_index - zone_bar) >= lookback_period and is_cleared
                array.remove(zone_prices, i)
                array.remove(zone_volumes, i)
                array.remove(zone_cleared, i)
                array.remove(zone_bars, i)
            i -= 1

// Update zones on each bar
update_liquidity_zones()

// Find maximum volume for normalization
get_max_volume() =>
    max_val = 0.0
    // Ensure arrays have elements and are synchronized
    if array.size(zone_volumes) > 0 and array.size(zone_volumes) == array.size(zone_cleared)
        for i = 0 to array.size(zone_volumes) - 1
            if not array.get(zone_cleared, i)
                val = array.get(zone_volumes, i)
                if val > max_val
                    max_val := val
    max_val

max_volume = get_max_volume()

// ============================================================================
// VISUALIZATION
// ============================================================================

// Determine heatmap position (calculate on every bar for consistency)
heatmap_start_x = position == "Left" ? bar_index - lookback_period : bar_index

// Debug: Show zone count on last bar
if barstate.islast and show_heatmap
    debug_text = "Zones: " + str.tostring(array.size(zone_prices)) + " | Max Vol: " + str.tostring(max_volume)
    label.new(bar_index, high, debug_text, color=color.new(color.blue, 20), textcolor=color.white, size=size.small, style=label.style_label_down)

// Draw heatmap using lines (more reliable than boxes)
if show_heatmap and max_volume > 0 and array.size(zone_prices) > 0
    for i = 0 to array.size(zone_prices) - 1
        zone_price = array.get(zone_prices, i)
        zone_vol = array.get(zone_volumes, i)
        is_cleared = array.get(zone_cleared, i)

        // Skip cleared zones unless option is enabled
        if is_cleared and not show_cleared_zones
            continue

        // Normalize volume - use very low threshold to show everything
        normalized_vol = zone_vol / max_volume
        threshold = 0.01  // Show zones with at least 1% of max volume

        if normalized_vol >= threshold
            // Determine color
            price_diff_pct = (zone_price - close) / close

            heatmap_color = if is_cleared
                color_cleared
            else if price_diff_pct > 0.01
                color_bullish  // Above price = long liquidations
            else if price_diff_pct < -0.01
                color_bearish  // Below price = short liquidations
            else
                color_neutral

            // Calculate line width based on intensity (1-5 pixels)
            line_width = math.max(1, math.round(normalized_vol * 5))
            line_opacity = is_cleared ? 30 : math.round(heatmap_opacity * normalized_vol)

            // Draw horizontal line extending to the right
            line_start_x = heatmap_start_x
            line_end_x = heatmap_start_x + heatmap_width

            // Only draw on last bar to avoid creating too many lines
            if barstate.islast
                line.new(
                     x1=line_start_x,
                     y1=zone_price,
                     x2=line_end_x,
                     y2=zone_price,
                     color=color.new(heatmap_color, 100 - line_opacity),
                     width=line_width,
                     style=line.style_solid,
                     extend=extend.right)

// ============================================================================
// ALERTS
// ============================================================================
approaching_zone = false
if barstate.islast and max_volume > 0
    for i = 0 to array.size(zone_prices) - 1
        if not array.get(zone_cleared, i)
            zone_price = array.get(zone_prices, i)
            zone_vol = array.get(zone_volumes, i)
            normalized = zone_vol / max_volume

            if normalized >= (min_volume_threshold / 10.0)
                distance_pct = math.abs(close - zone_price) / close
                if distance_pct < 0.005  // Within 0.5%
                    approaching_zone := true
                    break

alertcondition(
     condition=approaching_zone,
     title="Approaching Liquidation Zone",
     message="Price is approaching a key liquidation zone")
